---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
import sketchSvg from "../assets/sketch.svg";
---

<section 
  class="hero-section py-40 md:py-64 bg-gradient-to-b from-background to-surface relative overflow-hidden" 
  aria-labelledby="hero-heading"
  style={`--sketch-svg: url('${sketchSvg.src}')`}
>
  <div class="max-w-6xl mx-auto px-4 text-center">
  <ScrollReveal client:load>
    <h1 id="hero-heading" class="text-5xl md:text-6xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">
      Astro Theme Switcher
    </h1>
  </ScrollReveal>
  <ScrollReveal client:load delay={0.2}>
    <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto" style="color: var(--token-color-text-muted, #374151);">
      A production-ready, token-based themeable design system for Astro. Build beautiful websites with runtime theme switching, semantic design tokens, and a comprehensive component library.
    </p>
  </ScrollReveal>
  <ScrollReveal client:load delay={0.4}>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://buy.stripe.com/8x2dR9dcZfiu4R57mX4Ja01"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-lg transition-colors font-medium"
        style="background-color: var(--token-color-primary, #000000); color: var(--token-color-primary-foreground, #ffffff);"
        onmouseenter={(e) => e.currentTarget.style.opacity = '0.9'}
        onmouseleave={(e) => e.currentTarget.style.opacity = '1'}
        aria-label="Buy this template on Stripe (opens in new tab)"
      >
        <Icon name="tabler:shopping-cart" class="w-5 h-5" aria-hidden="true" />
        <span>Buy this template</span>
      </a>
      <a
        href="/about"
        class="inline-block px-8 py-3 border rounded-lg transition-colors font-medium"
        style="background-color: var(--token-color-background, #ffffff); color: var(--token-color-text-primary, #111827); border-color: var(--token-color-border, #e5e7eb);"
        onmouseenter={(e) => e.currentTarget.style.backgroundColor = 'var(--token-color-accent, rgba(0, 0, 0, 0.05))'}
        onmouseleave={(e) => e.currentTarget.style.backgroundColor = 'var(--token-color-background, #ffffff)'}
      >
        About Astro Theme Switcher
      </a>
    </div>
  </ScrollReveal>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    background-color: var(--token-color-primary, #2563eb);
    mask-image: var(--sketch-svg);
    -webkit-mask-image: var(--sketch-svg);
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center;
    -webkit-mask-position: center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    opacity: 0.1;
    transition: background-color var(--token-motion-duration-normal, 200ms) var(--token-motion-easing-default, cubic-bezier(0.4, 0, 0.2, 1));
  }

  /* Ensure Hero content is above the background */
  .hero-section > div {
    position: relative;
    z-index: 1;
  }
</style>
