---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="features" class="max-w-6xl mx-auto px-4 py-20">
  <ScrollReveal client:idle delay={0.1}>
    <h2 class="text-4xl font-bold text-center mb-12" style="color: var(--token-color-text-primary, #111827);">Features</h2>
  </ScrollReveal>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
    <ScrollReveal client:idle delay={0.2} scale={true}>
      <a
        href="/theme"
        class="block p-6 rounded-lg border transition-all cursor-pointer h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb); transition-duration: var(--token-motion-duration-normal); transition-timing-function: var(--token-motion-easing-default);"
        onmouseenter={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
          e.currentTarget.style.borderColor = 'var(--token-color-primary)';
          e.currentTarget.style.boxShadow = 'var(--token-shadow-2)';
        }}
        onmouseleave={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-background, #ffffff)';
          e.currentTarget.style.borderColor = 'var(--token-color-border, #e5e7eb)';
          e.currentTarget.style.boxShadow = 'none';
        }}
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:palette" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Theming</h3>
        <p class="min-h-[4.5rem] flex-1" style="color: var(--token-color-text-muted, #374151);">
          Built-in theme switcher with multiple color schemes. Switch between light, dark, and custom color themes with smooth transitions and persistent preferences across all pages.
        </p>
      </a>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.3} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:transition-right" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">View Transitions</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Smooth page transitions powered by Astro's view transitions API. Enjoy seamless navigation with animated elements that persist across page changes and enhance user experience.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.4} scale={true}>
      <a
        href="/components"
        class="block p-6 rounded-lg border transition-all cursor-pointer h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb); transition-duration: var(--token-motion-duration-normal); transition-timing-function: var(--token-motion-easing-default);"
        onmouseenter={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
          e.currentTarget.style.borderColor = 'var(--token-color-primary)';
          e.currentTarget.style.boxShadow = 'var(--token-shadow-2)';
        }}
        onmouseleave={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-background, #ffffff)';
          e.currentTarget.style.borderColor = 'var(--token-color-border, #e5e7eb)';
          e.currentTarget.style.boxShadow = 'none';
        }}
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:components" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Components</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Production-ready component library with Button, Card, Alert, Badge, Input, and more. All components are theme-aware and accessible by default for all users.
        </p>
      </a>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.5} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:brand-react" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">React</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Component-based UI library for building interactive interfaces. Seamlessly integrated with Astro for dynamic components and enhanced user experiences.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.5} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon
            name="tabler:brand-framer-motion"
            class="w-6 h-6"
          style="color: var(--token-color-text-primary, #111827);"
            aria-hidden="true"
          />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Framer Motion</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Production-ready motion library for React. Create smooth animations and delightful user experiences with spring physics and advanced transitions.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.6} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:brand-tailwind" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Tailwind CSS</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Utility-first CSS framework for rapid UI development. Build beautiful, responsive designs with ease and no custom CSS needed for faster development.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.8} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:icons" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Astro Icons</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Beautiful icon component library for Astro. Access thousands of icons from popular icon sets with zero runtime overhead and easy integration.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={1.0} scale={true}>
      <div
        class="p-6 rounded-lg border hover:shadow-lg transition-shadow h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:brand-sass" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Sass</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          CSS preprocessor with variables, mixins, and nesting. Use Sass alongside Tailwind for advanced styling needs and complex layouts with ease.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={1.1} scale={true}>
      <a
        href="/example"
        class="block p-6 rounded-lg border transition-all cursor-pointer h-full flex flex-col"
        style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb); transition-duration: var(--token-motion-duration-normal); transition-timing-function: var(--token-motion-easing-default);"
        onmouseenter={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
          e.currentTarget.style.borderColor = 'var(--token-color-primary)';
          e.currentTarget.style.boxShadow = 'var(--token-shadow-2)';
        }}
        onmouseleave={(e) => {
          e.currentTarget.style.backgroundColor = 'var(--token-color-background, #ffffff)';
          e.currentTarget.style.borderColor = 'var(--token-color-border, #e5e7eb)';
          e.currentTarget.style.boxShadow = 'none';
        }}
      >
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center mb-4"
          style="background-color: var(--token-color-surface, #f9fafb);"
        >
          <Icon name="tabler:markdown" class="w-6 h-6" style="color: var(--token-color-text-primary, #111827);" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">MDX</h3>
        <p class="min-h-[4.5rem]" style="color: var(--token-color-text-muted, #374151);">
          Write JSX in your Markdown documents. Perfect for blog posts, documentation, and content-rich pages with full component support and flexibility.
        </p>
      </a>
    </ScrollReveal>
  </div>
</section>
