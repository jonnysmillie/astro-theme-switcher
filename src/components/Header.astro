---
import { Icon } from "astro-icon/components";
import ThemeSwitcher from "./ThemeSwitcher.tsx";
import ModeToggle from "./ModeToggle.tsx";
---

<header
  class="w-full sticky top-0 z-50"
  role="banner"
  style="background-color: var(--token-color-background, #ffffff);"
>
  <div class="w-full border-b" style="border-color: var(--token-color-border, #e5e7eb);">
    <nav
      class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between"
      aria-label="Main navigation"
    >
    <a
      href="/"
      class="text-2xl font-bold transition-colors"
      style="color: var(--token-color-text-primary, #111827);"
      onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-primary, #000000)'}
      onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
      aria-label="Astro Theme Switcher - Home"
    >
      Astro Theme Switcher
    </a>
    
    <!-- Mobile menu button -->
    <button
      type="button"
      class="md:hidden p-2 focus:outline-none focus:ring-2 rounded-lg transition-colors"
      style="color: var(--token-color-text-muted, #6b7280);"
      onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
      onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)'}
      onfocus={(e) => {
        e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
        e.currentTarget.style.outline = '2px solid var(--token-color-primary, #000000)';
        e.currentTarget.style.outlineOffset = '2px';
      }}
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <Icon name="tabler:menu-2" class="w-6 h-6" aria-hidden="true" />
    </button>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex items-center gap-6" role="list">
      <li>
        <a
          href="/blog"
          class="transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
          onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)'}
          aria-current={Astro.url.pathname.startsWith('/blog') ? 'page' : undefined}
        >
          Blog
        </a>
      </li>
      <li>
        <a
          href="/features"
          class="transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
          onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)'}
          aria-current={Astro.url.pathname === '/features' ? 'page' : undefined}
        >
          Features
        </a>
      </li>
      <li>
        <a
          href="/about"
          class="transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
          onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)'}
          aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="px-4 py-2 rounded-lg transition-colors"
          style="background-color: var(--token-color-primary, #000000); color: var(--token-color-primary-foreground, #ffffff);"
          onmouseenter={(e) => {
            const primary = getComputedStyle(document.documentElement).getPropertyValue('--token-color-primary').trim();
            e.currentTarget.style.opacity = '0.9';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.opacity = '1';
          }}
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
      <li class="flex items-center gap-2">
        <ModeToggle client:load />
        <ThemeSwitcher client:load />
      </li>
    </ul>
  </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden w-full border-t border-b"
    role="menu"
    aria-labelledby="mobile-menu-button"
    style="background-color: var(--token-color-background, #ffffff); border-color: var(--token-color-border, #e5e7eb);"
  >
    <ul class="flex flex-col py-4" role="list">
      <li>
        <a
          href="/blog"
          class="block px-4 py-3 transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
            e.currentTarget.style.backgroundColor = 'var(--token-color-accent, rgba(0, 0, 0, 0.05))';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)';
            e.currentTarget.style.backgroundColor = 'transparent';
          }}
          role="menuitem"
          aria-current={Astro.url.pathname.startsWith('/blog') ? 'page' : undefined}
        >
          Blog
        </a>
      </li>
      <li>
        <a
          href="/features"
          class="block px-4 py-3 transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
            e.currentTarget.style.backgroundColor = 'var(--token-color-accent, rgba(0, 0, 0, 0.05))';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)';
            e.currentTarget.style.backgroundColor = 'transparent';
          }}
          role="menuitem"
          aria-current={Astro.url.pathname === '/features' ? 'page' : undefined}
        >
          Features
        </a>
      </li>
      <li>
        <a
          href="/about"
          class="block px-4 py-3 transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
            e.currentTarget.style.backgroundColor = 'var(--token-color-accent, rgba(0, 0, 0, 0.05))';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)';
            e.currentTarget.style.backgroundColor = 'transparent';
          }}
          role="menuitem"
          aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="block px-4 py-3 transition-colors"
          style="color: var(--token-color-text-muted, #6b7280);"
          onmouseenter={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
            e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.color = 'var(--token-color-text-muted, #6b7280)';
            e.currentTarget.style.backgroundColor = 'transparent';
          }}
          role="menuitem"
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
      <li class="px-4 py-3">
        <div class="flex items-center gap-3">
          <ModeToggle client:load />
          <ThemeSwitcher client:load />
        </div>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (function() {
    function initMenu() {
      var button = document.getElementById('mobile-menu-button');
      var menu = document.getElementById('mobile-menu');
      
      if (!button || !menu) {
        setTimeout(initMenu, 100);
        return;
      }
      
      button.onclick = function(e) {
        e.preventDefault();
        e.stopPropagation();
        var isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isExpanded));
        if (isExpanded) {
          menu.classList.add('hidden');
        } else {
          menu.classList.remove('hidden');
        }
      };
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMenu);
    } else {
      setTimeout(initMenu, 0);
    }
    
    document.addEventListener('astro:page-load', initMenu);
    document.addEventListener('astro:after-swap', initMenu);
  })();
</script>
