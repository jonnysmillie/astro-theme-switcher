---
import { Icon } from "astro-icon/components";
---

<footer
  id="contact"
  class="w-full py-12"
  role="contentinfo"
  style="background-color: var(--token-color-background, #ffffff);"
>
  <div class="w-full border-t mb-12" style="border-color: var(--token-color-border, #e5e7eb);"></div>
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Astro Theme Switcher</h2>
        <p style="color: var(--token-color-text-muted, #4b5563);">
          A production-ready, token-based themeable design system for Astro. Build beautiful websites with runtime theme switching and semantic design tokens.
        </p>
      </div>
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Links</h2>
        <ul class="space-y-2">
          <li>
            <a
              href="/blog"
              class="transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              >Blog</a
            >
          </li>
          <li>
            <a
              href="/features"
              class="transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              >Features</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              >About</a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              >Contact</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Connect</h2>
        <ul class="space-y-2">
          <li>
            <a
              href="https://jonnysmillie.dev"
              class="flex items-center gap-2 transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit jonnysmillie.dev (opens in new tab)"
            >
              <Icon name="tabler:world" class="w-5 h-5" aria-hidden="true" />
              <span>Website</span></a
            >
          </li>
          <li>
            <a
              href="https://x.com/jonnysmillie"
              class="flex items-center gap-2 transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Follow @jonnysmillie on X (opens in new tab)"
            >
              <Icon name="tabler:brand-x" class="w-5 h-5" aria-hidden="true" />
              <span>X</span></a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="flex items-center gap-2 transition-colors"
              style="color: var(--token-color-text-muted, #4b5563);"
              onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
              onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
            >
              <Icon name="tabler:mail" class="w-5 h-5" aria-hidden="true" />
              <span>Email</span></a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="w-full border-t pt-8" style="border-color: var(--token-color-border, #e5e7eb);">
      <div class="max-w-6xl mx-auto px-4 text-center" style="color: var(--token-color-text-muted, #4b5563);">
        <p>
          &copy; {new Date().getFullYear()} Astro Theme Switcher. All rights reserved. Made by{' '}
          <a
            href="https://jonnysmillie.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors"
            style="color: var(--token-color-text-muted, #4b5563);"
            onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
            onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #4b5563)'}
            aria-label="Visit Jonny Smillie's website (opens in new tab)"
          >
            Jonny Smillie
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
