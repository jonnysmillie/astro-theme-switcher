---
/**
 * Badge Component
 * 
 * A theme-aware badge component for labels and status indicators.
 * 
 * Architecture Decisions:
 * 1. Variants map to semantic state tokens - clear meaning (success = success color)
 * 2. Rounded-full for pill shape - standard badge pattern
 * 3. Size variants for different contexts - flexible usage
 * 4. Pure Astro component - no framework dependencies
 * 
 * Use for: Status indicators, labels, tags, counts, notifications
 */

export interface Props {
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error' | 'info';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  class: className = '',
} = Astro.props;

const baseClasses = 'inline-flex items-center font-medium rounded-full';
const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2.5 py-1 text-sm',
  lg: 'px-3 py-1.5 text-base',
};

const variantStyles = {
  default: {
    background: 'var(--token-color-surface)',
    color: 'var(--token-color-text-primary)',
  },
  primary: {
    background: 'var(--token-color-primary)',
    color: 'var(--token-color-primary-foreground)',
  },
  success: {
    background: 'var(--token-color-success)',
    color: 'var(--token-color-success-foreground)',
  },
  warning: {
    background: 'var(--token-color-warning)',
    color: 'var(--token-color-warning-foreground)',
  },
  error: {
    background: 'var(--token-color-error)',
    color: 'var(--token-color-error-foreground)',
  },
  info: {
    background: 'var(--token-color-info)',
    color: 'var(--token-color-info-foreground)',
  },
};

const style = variantStyles[variant];
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<span
  class={`${baseClasses} ${sizeClasses[size]} ${className}`}
  style={`
    background-color: ${style.background};
    color: ${style.color};
    transition-duration: ${motionDuration};
    transition-timing-function: ${motionEasing};
  `}
>
  <slot />
</span>
