---
/**
 * Navbar Component
 * 
 * A theme-aware navigation bar component.
 * 
 * Architecture Note: This is an example/wrapper component showing how to build
 * a navbar using the token system. The actual Header.astro can be refactored to
 * use this pattern, or you can use Header.astro as-is.
 * 
 * Architecture Decisions:
 * 1. Full-width border separated from content - consistent border system
 * 2. Hover states use motion tokens - smooth, consistent transitions
 * 3. Current page indication via data attribute - semantic and accessible
 * 4. Responsive by default - mobile menu pattern can be added
 * 
 * This component demonstrates navigation patterns using only tokens.
 */

export interface NavItem {
  label: string;
  href: string;
  current?: boolean;
}

export interface Props {
  brand?: string;
  brandHref?: string;
  items?: NavItem[];
  class?: string;
}

const {
  brand = 'Astro Theme Switcher',
  brandHref = '/',
  items = [],
  class: className = '',
} = Astro.props;

const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<nav
  class={`w-full sticky top-0 z-50 ${className}`}
  role="navigation"
  aria-label="Main navigation"
  style="background-color: var(--token-color-background);"
>
  <div class="w-full border-b" style="border-color: var(--token-color-border);">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a
        href={brandHref}
        class="text-2xl font-bold transition-colors"
        style="color: var(--token-color-text-primary);"
        onmouseenter={(e) => {
          e.currentTarget.style.color = 'var(--token-color-primary)';
        }}
        onmouseleave={(e) => {
          e.currentTarget.style.color = 'var(--token-color-text-primary)';
        }}
      >
        {brand}
      </a>
      
      <ul class="hidden md:flex items-center gap-6" role="list">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class="transition-colors"
              style={`
                color: ${item.current ? 'var(--token-color-text-primary)' : 'var(--token-color-text-muted)'};
                transition-duration: ${motionDuration};
                transition-timing-function: ${motionEasing};
              `}
              onmouseenter={(e) => {
                e.currentTarget.style.color = 'var(--token-color-text-primary)';
              }}
              onmouseleave={(e) => {
                e.currentTarget.style.color = item.current ? 'var(--token-color-text-primary)' : 'var(--token-color-text-muted)';
              }}
              aria-current={item.current ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>
