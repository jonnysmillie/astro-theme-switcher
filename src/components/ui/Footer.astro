---
/**
 * Footer Component
 * 
 * A theme-aware footer component with flexible section support.
 * 
 * Architecture Note: This is an example component showing footer patterns.
 * The actual Footer.astro can be refactored to use this, or kept as-is.
 * 
 * Architecture Decisions:
 * 1. Full-width borders - consistent with header/navbar pattern
 * 2. Grid layout for sections - responsive, flexible
 * 3. Hover states on links - clear interactivity
 * 4. All colors from tokens - adapts to any theme
 * 
 * This demonstrates how to build complex layouts using only semantic tokens.
 */

export interface FooterLink {
  label: string;
  href: string;
}

export interface FooterSection {
  title: string;
  links: FooterLink[];
}

export interface Props {
  brand?: string;
  description?: string;
  sections?: FooterSection[];
  copyright?: string;
  class?: string;
}

const {
  brand = 'Astro Theme Switcher',
  description,
  sections = [],
  copyright,
  class: className = '',
} = Astro.props;

const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<footer
  class={`w-full py-12 ${className}`}
  role="contentinfo"
  style="background-color: var(--token-color-background);"
>
  <div class="w-full border-t mb-12" style="border-color: var(--token-color-border);"></div>
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h2
          class="text-lg font-semibold mb-4"
          style="color: var(--token-color-text-primary);"
        >
          {brand}
        </h2>
        {description && (
          <p style="color: var(--token-color-text-muted);">
            {description}
          </p>
        )}
      </div>
      
      {sections.map((section) => (
        <div>
          <h3
            class="text-sm font-semibold mb-4"
            style="color: var(--token-color-text-primary);"
          >
            {section.title}
          </h3>
          <ul class="space-y-2">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="transition-colors"
                  style={`
                    color: var(--token-color-text-muted);
                    transition-duration: ${motionDuration};
                    transition-timing-function: ${motionEasing};
                  `}
                  onmouseenter={(e) => {
                    e.currentTarget.style.color = 'var(--token-color-text-primary)';
                  }}
                  onmouseleave={(e) => {
                    e.currentTarget.style.color = 'var(--token-color-text-muted)';
                  }}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="w-full border-t pt-8" style="border-color: var(--token-color-border);">
      <div class="text-center" style="color: var(--token-color-text-muted);">
        <p>
          {copyright || `© ${new Date().getFullYear()} ${brand}. All rights reserved.`}
        </p>
      </div>
    </div>
  </div>
</footer>
