---
/**
 * Card Component
 * 
 * A theme-aware card component with elevation variants.
 * 
 * Architecture Decisions:
 * 1. Uses semantic tokens exclusively - no hardcoded colors or shadows
 * 2. Elevation variants map to shadow tokens - consistent depth system
 * 3. Padding is configurable but uses standard sizes - maintains design consistency
 * 4. Motion tokens for transitions - respects user's motion preferences
 * 
 * This component is pure Astro - no framework dependencies.
 * Works seamlessly with the token system across all themes.
 */

export interface Props {
  variant?: 'default' | 'elevated' | 'outlined';
  padding?: 'none' | 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  variant = 'default',
  padding = 'md',
  class: className = '',
} = Astro.props;

const baseClasses = 'rounded-lg transition-all';
const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const variantStyles = {
  default: {
    background: 'var(--token-color-surface)',
    border: 'none',
    shadow: 'var(--token-shadow-1)',
  },
  elevated: {
    background: 'var(--token-color-surface-elevated)',
    border: 'none',
    shadow: 'var(--token-shadow-3)',
  },
  outlined: {
    background: 'var(--token-color-surface)',
    border: '1px solid var(--token-color-border)',
    shadow: 'none',
  },
};

const style = variantStyles[variant];
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<div
  class={`${baseClasses} ${paddingClasses[padding]} ${className}`}
  style={`
    background-color: ${style.background};
    ${style.border ? `border: ${style.border};` : ''}
    ${style.shadow ? `box-shadow: ${style.shadow};` : ''}
    transition-duration: ${motionDuration};
    transition-timing-function: ${motionEasing};
  `}
>
  <slot />
</div>
