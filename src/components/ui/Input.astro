---
/**
 * Input Component
 * 
 * A theme-aware input component with error and disabled states.
 * 
 * Architecture Decisions:
 * 1. Accessible by default - proper ARIA attributes, labels, error associations
 * 2. Error states use semantic error tokens - consistent across all themes
 * 3. Focus states use focus token - respects theme's focus color
 * 4. Auto-generated IDs prevent conflicts - each instance is unique
 * 5. Motion tokens for focus transitions - smooth, consistent animations
 * 
 * This component follows WCAG guidelines and works across all themes.
 * No framework dependencies - pure Astro component.
 */

export interface Props {
  type?: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search';
  label?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  error?: string;
  id?: string;
  name?: string;
  class?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
}

const {
  type = 'text',
  label,
  placeholder,
  value,
  required = false,
  disabled = false,
  error,
  id = `input-${Math.random().toString(36).substr(2, 9)}`,
  name,
  class: className = '',
  ariaLabel,
  ariaDescribedBy,
} = Astro.props;

const baseClasses = 'w-full px-4 py-3 rounded-lg border outline-none transition-all';
const errorId = error ? `${id}-error` : undefined;
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<div class={`${className}`}>
  {label && (
    <label
      for={id}
      class="block text-sm font-medium mb-2"
      style="color: var(--token-color-text-primary);"
    >
      {label}
      {required && (
        <span class="ml-1" style="color: var(--token-color-error);" aria-label="required">*</span>
      )}
    </label>
  )}
  <input
    type={type}
    id={id}
    name={name || id}
    value={value}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    aria-label={ariaLabel || label}
    aria-describedby={ariaDescribedBy || errorId}
    aria-invalid={error ? 'true' : 'false'}
    aria-required={required ? 'true' : 'false'}
    class={baseClasses}
    style={`
      background-color: var(--token-color-background);
      color: var(--token-color-text-primary);
      border-color: ${error ? 'var(--token-color-error)' : 'var(--token-color-border)'};
      border-width: 1px;
      transition-duration: ${motionDuration};
      transition-timing-function: ${motionEasing};
    `}
    onfocus={(e) => {
      e.currentTarget.style.borderColor = 'var(--token-color-focus)';
      e.currentTarget.style.outline = '2px solid var(--token-color-focus)';
      e.currentTarget.style.outlineOffset = '2px';
    }}
    onblur={(e) => {
      e.currentTarget.style.borderColor = error ? 'var(--token-color-error)' : 'var(--token-color-border)';
      e.currentTarget.style.outline = '';
      e.currentTarget.style.outlineOffset = '';
    }}
  />
  {error && (
    <p
      id={errorId}
      class="mt-2 text-sm"
      role="alert"
      style="color: var(--token-color-error);"
    >
      {error}
    </p>
  )}
</div>
