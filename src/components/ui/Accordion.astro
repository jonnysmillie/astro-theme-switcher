---
/**
 * Accordion Component
 * 
 * A theme-aware accordion component for collapsible content sections.
 * 
 * Architecture Decisions:
 * 1. Uses semantic tokens exclusively - no hardcoded colors
 * 2. Accessible by default - ARIA attributes, keyboard navigation
 * 3. Supports single or multiple open items - flexible usage
 * 4. Smooth animations using motion tokens - consistent timing
 * 5. Icon customization - flexible appearance
 * 
 * This component requires client-side JavaScript for interactivity.
 * Use with client:load or client:visible directive.
 */

export interface AccordionItem {
  id: string;
  title: string;
  content: string;
  defaultOpen?: boolean;
}

export interface Props {
  items: AccordionItem[];
  allowMultiple?: boolean;
  variant?: 'default' | 'bordered' | 'flush';
  class?: string;
}

const {
  items,
  allowMultiple = false,
  variant = 'default',
  class: className = '',
} = Astro.props;

const variantStyles = {
  default: {
    border: '1px solid var(--token-color-border, #e5e7eb)',
    borderRadius: 'var(--token-radius-lg, 0.5rem)',
    spacing: 'mb-2',
  },
  bordered: {
    border: '1px solid var(--token-color-border, #e5e7eb)',
    borderRadius: 'var(--token-radius-md, 0.375rem)',
    spacing: 'mb-1',
  },
  flush: {
    border: 'none',
    borderRadius: '0',
    spacing: 'mb-0',
  },
};

const style = variantStyles[variant];
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
const accordionId = `accordion-${Math.random().toString(36).substr(2, 9)}`;
---

<div class={`${className}`} role="group">
  {items.map((item, index) => {
    const itemId = `${accordionId}-item-${index}`;
    const contentId = `${itemId}-content`;
    const isOpen = item.defaultOpen || false;
    
    return (
      <div
        key={item.id}
        class={style.spacing}
        style={`
          ${style.border ? `border: ${style.border};` : ''}
          border-radius: ${style.borderRadius};
          overflow: hidden;
        `}
      >
        <button
          type="button"
          class="w-full flex items-center justify-between p-4 text-left transition-colors cursor-pointer"
          style={`
            background-color: var(--token-color-surface, #f9fafb);
            color: var(--token-color-text-primary, #111827);
            transition-duration: ${motionDuration};
            transition-timing-function: ${motionEasing};
          `}
          aria-expanded={isOpen ? 'true' : 'false'}
          aria-controls={contentId}
          onclick={`
            const button = event.currentTarget;
            const content = document.getElementById('${contentId}');
            const isExpanded = button.getAttribute('aria-expanded') === 'true';
            
            ${!allowMultiple ? `
              // Close all other items
              const allButtons = document.querySelectorAll('[aria-controls^="${accordionId}-item"]');
              const allContents = document.querySelectorAll('[id^="${accordionId}-item"][id$="-content"]');
              allButtons.forEach(btn => {
                if (btn !== button) {
                  btn.setAttribute('aria-expanded', 'false');
                  btn.querySelector('svg').style.transform = 'rotate(0deg)';
                }
              });
              allContents.forEach(ctn => {
                if (ctn !== content) {
                  ctn.style.maxHeight = '0';
                  ctn.style.opacity = '0';
                }
              });
            ` : ''}
            
            // Toggle current item
            if (isExpanded) {
              button.setAttribute('aria-expanded', 'false');
              button.querySelector('svg').style.transform = 'rotate(0deg)';
              content.style.maxHeight = '0';
              content.style.opacity = '0';
            } else {
              button.setAttribute('aria-expanded', 'true');
              button.querySelector('svg').style.transform = 'rotate(180deg)';
              content.style.maxHeight = content.scrollHeight + 'px';
              content.style.opacity = '1';
            }
          `}
          onmouseenter={(e) => {
            e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
          }}
          onmouseleave={(e) => {
            e.currentTarget.style.backgroundColor = 'var(--token-color-surface, #f9fafb)';
          }}
        >
          <span class="font-medium" style="color: var(--token-color-text-primary, #111827);">
            {item.title}
          </span>
          <svg
            class="ml-4 h-5 w-5 flex-shrink-0 transition-transform"
            style={`
              color: var(--token-color-text-muted, #6b7280);
              transform: ${isOpen ? 'rotate(180deg)' : 'rotate(0deg)'};
              transition-duration: ${motionDuration};
              transition-timing-function: ${motionEasing};
            `}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          id={contentId}
          class="overflow-hidden transition-all"
          style={`
            max-height: ${isOpen ? '1000px' : '0'};
            opacity: ${isOpen ? '1' : '0'};
            transition-duration: ${motionDuration};
            transition-timing-function: ${motionEasing};
          `}
          aria-hidden={isOpen ? 'false' : 'true'}
        >
          <div
            class="p-4"
            style="background-color: var(--token-color-background, #ffffff); color: var(--token-color-text-primary, #111827);"
          >
            {item.content}
          </div>
        </div>
      </div>
    );
  })}
</div>
