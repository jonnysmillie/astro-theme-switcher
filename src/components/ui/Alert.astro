---
/**
 * Alert Component
 * 
 * A theme-aware alert component with semantic variants.
 * 
 * Architecture Decisions:
 * 1. Variants map to semantic state tokens (success, warning, error, info)
 *    This ensures alerts use appropriate colors for their purpose
 * 2. ARIA role="alert" for screen readers - accessibility first
 * 3. Dismissible option uses simple onclick - no framework dependency
 * 4. All colors from tokens - works across all themes automatically
 * 
 * This component is pure Astro - no framework dependencies.
 */

export interface Props {
  variant?: 'success' | 'warning' | 'error' | 'info';
  title?: string;
  dismissible?: boolean;
  class?: string;
}

const {
  variant = 'info',
  title,
  dismissible = false,
  class: className = '',
} = Astro.props;

const baseClasses = 'p-4 rounded-lg border flex items-start gap-3';
const variantStyles = {
  success: {
    background: 'var(--token-color-success)',
    foreground: 'var(--token-color-success-foreground)',
    border: 'var(--token-color-success)',
  },
  warning: {
    background: 'var(--token-color-warning)',
    foreground: 'var(--token-color-warning-foreground)',
    border: 'var(--token-color-warning)',
  },
  error: {
    background: 'var(--token-color-error)',
    foreground: 'var(--token-color-error-foreground)',
    border: 'var(--token-color-error)',
  },
  info: {
    background: 'var(--token-color-info)',
    foreground: 'var(--token-color-info-foreground)',
    border: 'var(--token-color-info)',
  },
};

const style = variantStyles[variant];
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
const alertId = `alert-${Math.random().toString(36).substr(2, 9)}`;
---

<div
  id={alertId}
  role="alert"
  class={`${baseClasses} ${className}`}
  style={`
    background-color: ${style.background};
    color: ${style.foreground};
    border-color: ${style.border};
    border-width: 1px;
    transition-duration: ${motionDuration};
    transition-timing-function: ${motionEasing};
  `}
>
  <div class="flex-1">
    {title && (
      <h4 class="font-semibold mb-1" style="color: var(--token-color-text-inverse, #ffffff);">
        {title}
      </h4>
    )}
    <div class="text-sm">
      <slot />
    </div>
  </div>
  {dismissible && (
    <button
      type="button"
      class="ml-auto p-1 rounded hover:opacity-70 transition-opacity"
      style={`
        color: ${style.foreground};
        transition-duration: ${motionDuration};
        transition-timing-function: ${motionEasing};
      `}
      onclick={`
        document.getElementById('${alertId}').style.display = 'none';
      `}
      aria-label="Dismiss alert"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  )}
</div>
