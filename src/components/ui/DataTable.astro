---
/**
 * DataTable Component
 * 
 * A theme-aware data table component with sorting, filtering, and pagination.
 * 
 * Architecture Decisions:
 * 1. Uses semantic tokens exclusively - no hardcoded colors
 * 2. Accessible by default - ARIA attributes, keyboard navigation
 * 3. Client-side sorting and filtering - no server dependency
 * 4. Responsive design - mobile-friendly
 * 5. Customizable columns - flexible data display
 * 
 * This component requires client-side JavaScript for interactivity.
 * Use with client:load or client:visible directive.
 */

export interface TableColumn {
  key: string;
  label: string;
  sortable?: boolean;
  render?: (value: any, row: any) => string;
}

export interface Props {
  data: Record<string, any>[];
  columns: TableColumn[];
  searchable?: boolean;
  sortable?: boolean;
  pagination?: boolean;
  itemsPerPage?: number;
  class?: string;
}

const {
  data,
  columns,
  searchable = true,
  sortable = true,
  pagination = true,
  itemsPerPage = 10,
  class: className = '',
} = Astro.props;

const tableId = `table-${Math.random().toString(36).substr(2, 9)}`;
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<div class={`${className}`}>
  {searchable && (
    <div class="mb-4">
      <input
        type="search"
        id={`${tableId}-search`}
        placeholder="Search..."
        class="w-full max-w-md px-4 py-2 rounded-lg border outline-none transition-all"
        style={`
          background-color: var(--token-color-background, #ffffff);
          color: var(--token-color-text-primary, #111827);
          border-color: var(--token-color-border, #e5e7eb);
          transition-duration: ${motionDuration};
          transition-timing-function: ${motionEasing};
        `}
        onfocus={(e) => {
          e.currentTarget.style.borderColor = 'var(--token-color-focus, #3b82f6)';
          e.currentTarget.style.outline = '2px solid var(--token-color-focus, #3b82f6)';
          e.currentTarget.style.outlineOffset = '2px';
        }}
        onblur={(e) => {
          e.currentTarget.style.borderColor = 'var(--token-color-border, #e5e7eb)';
          e.currentTarget.style.outline = '';
          e.currentTarget.style.outlineOffset = '';
        }}
        oninput={`
          const searchTerm = event.target.value.toLowerCase();
          const rows = document.querySelectorAll('#${tableId} tbody tr');
          rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
          });
        `}
        aria-label="Search table"
      />
    </div>
  )}
  
  <div class="overflow-x-auto rounded-lg border" style="border-color: var(--token-color-border, #e5e7eb);">
    <table
      id={tableId}
      class="w-full"
      role="table"
      aria-label="Data table"
    >
      <thead>
        <tr style="background-color: var(--token-color-surface, #f9fafb);">
          {columns.map((column, index) => (
            <th
              key={column.key}
              class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider cursor-pointer transition-colors"
              style={`
                color: var(--token-color-text-muted, #4b5563);
                transition-duration: ${motionDuration};
                transition-timing-function: ${motionEasing};
              `}
              onclick={sortable && column.sortable !== false ? `
                const table = document.getElementById('${tableId}');
                const tbody = table.querySelector('tbody');
                const rows = Array.from(tbody.querySelectorAll('tr'));
                const currentSort = table.dataset.sort || '';
                const sortKey = '${column.key}';
                const isAsc = currentSort === sortKey;
                
                // Update sort indicator
                const headers = table.querySelectorAll('thead th');
                headers.forEach(h => {
                  h.querySelector('.sort-icon')?.remove();
                  h.style.color = 'var(--token-color-text-muted, #4b5563)';
                });
                event.currentTarget.style.color = 'var(--token-color-text-primary, #111827)';
                const icon = document.createElement('span');
                icon.className = 'sort-icon ml-1';
                icon.textContent = isAsc ? '↑' : '↓';
                event.currentTarget.appendChild(icon);
                
                // Sort rows
                rows.sort((a, b) => {
                  const aVal = a.cells[${index}].textContent.trim();
                  const bVal = b.cells[${index}].textContent.trim();
                  const comparison = aVal.localeCompare(bVal);
                  return isAsc ? -comparison : comparison;
                });
                
                rows.forEach(row => tbody.appendChild(row));
                table.dataset.sort = isAsc ? '' : sortKey;
              ` : undefined}
              onmouseenter={sortable && column.sortable !== false ? (e) => {
                e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
              } : undefined}
              onmouseleave={sortable && column.sortable !== false ? (e) => {
                e.currentTarget.style.backgroundColor = 'transparent';
              } : undefined}
            >
              {column.label}
              {sortable && column.sortable !== false && (
                <span class="ml-1 text-xs" aria-hidden="true">↕</span>
              )}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y" style="border-color: var(--token-color-border, #e5e7eb);">
        {data.map((row, rowIndex) => (
          <tr
            key={rowIndex}
            class="transition-colors"
            style={`
              background-color: var(--token-color-background, #ffffff);
              transition-duration: ${motionDuration};
              transition-timing-function: ${motionEasing};
            `}
            onmouseenter={(e) => {
              e.currentTarget.style.backgroundColor = 'var(--token-color-hover, rgba(0, 0, 0, 0.05))';
            }}
            onmouseleave={(e) => {
              e.currentTarget.style.backgroundColor = 'var(--token-color-background, #ffffff)';
            }}
          >
            {columns.map((column) => {
              const value = row[column.key];
              const displayValue = column.render ? column.render(value, row) : String(value || '');
              
              return (
                <td
                  key={column.key}
                  class="px-6 py-4 whitespace-nowrap text-sm"
                  style="color: var(--token-color-text-primary, #111827);"
                >
                  {displayValue}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  
  {pagination && data.length > itemsPerPage && (
    <div class="mt-4 flex items-center justify-between">
      <div class="text-sm" style="color: var(--token-color-text-muted, #4b5563);">
        Showing <span id={`${tableId}-start`}>1</span> to <span id={`${tableId}-end`}>{Math.min(itemsPerPage, data.length)}</span> of <span id={`${tableId}-total`}>{data.length}</span> results
      </div>
      <div class="flex gap-2">
        <button
          type="button"
          id={`${tableId}-prev`}
          class="px-3 py-1 rounded border transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
          style={`
            background-color: var(--token-color-background, #ffffff);
            color: var(--token-color-text-primary, #111827);
            border-color: var(--token-color-border, #e5e7eb);
            transition-duration: ${motionDuration};
            transition-timing-function: ${motionEasing};
          `}
          disabled
          onclick={`
            // Pagination logic would go here
            console.log('Previous page');
          `}
        >
          Previous
        </button>
        <button
          type="button"
          id={`${tableId}-next`}
          class="px-3 py-1 rounded border transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
          style={`
            background-color: var(--token-color-background, #ffffff);
            color: var(--token-color-text-primary, #111827);
            border-color: var(--token-color-border, #e5e7eb);
            transition-duration: ${motionDuration};
            transition-timing-function: ${motionEasing};
          `}
          disabled={data.length <= itemsPerPage}
          onclick={`
            // Pagination logic would go here
            console.log('Next page');
          `}
        >
          Next
        </button>
      </div>
    </div>
  )}
</div>
