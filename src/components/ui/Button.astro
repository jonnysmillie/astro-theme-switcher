---
/**
 * Button Component
 * 
 * A theme-aware, accessible button component with multiple variants.
 * 
 * Architecture Decisions:
 * 1. All colors use semantic tokens (--token-color-*) - no hardcoded values
 *    This ensures the button works across all themes automatically
 * 2. Supports both <button> and <a> elements - flexibility for different use cases
 * 3. Motion tokens used for transitions - consistent animation timing across system
 * 4. Inline event handlers for hover - simple, no framework dependency
 *    (Note: These are Astro-specific and work at build time)
 * 
 * This component is framework-agnostic (Astro) and can be used anywhere.
 * The only dependency is the token system - no React, Vue, or other frameworks required.
 */

export interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'success' | 'warning' | 'error';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  disabled = false,
  type = 'button',
  href,
  class: className = '',
  ariaLabel,
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed';
const sizeClasses = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-6 py-3 text-lg',
};
const variantStyles = {
  primary: {
    background: 'var(--token-color-primary)',
    color: 'var(--token-color-primary-foreground)',
    hover: 'opacity: 0.9',
    focus: 'var(--token-color-focus)',
  },
  secondary: {
    background: 'var(--token-color-secondary)',
    color: 'var(--token-color-secondary-foreground)',
    hover: 'opacity: 0.9',
    focus: 'var(--token-color-focus)',
  },
  outline: {
    background: 'transparent',
    color: 'var(--token-color-text-primary)',
    border: '1px solid var(--token-color-border)',
    hover: 'background-color: var(--token-color-hover)',
    focus: 'var(--token-color-focus)',
  },
  ghost: {
    background: 'transparent',
    color: 'var(--token-color-text-primary)',
    hover: 'background-color: var(--token-color-hover)',
    focus: 'var(--token-color-focus)',
  },
  success: {
    background: 'var(--token-color-success)',
    color: 'var(--token-color-success-foreground)',
    hover: 'opacity: 0.9',
    focus: 'var(--token-color-focus)',
  },
  warning: {
    background: 'var(--token-color-warning)',
    color: 'var(--token-color-warning-foreground)',
    hover: 'opacity: 0.9',
    focus: 'var(--token-color-focus)',
  },
  error: {
    background: 'var(--token-color-error)',
    color: 'var(--token-color-error-foreground)',
    hover: 'opacity: 0.9',
    focus: 'var(--token-color-focus)',
  },
};

const style = variantStyles[variant];
// Use motion tokens for consistent animation timing across all themes
const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

{/* 
  Architecture Decision: Support both <a> and <button> elements.
  This provides flexibility - use <a> for navigation, <button> for actions.
  Both share the same styling and variant system.
*/}
{href ? (
  <a
    href={href}
    class={`${baseClasses} ${sizeClasses[size]} ${className}`}
    style={`
      background-color: ${style.background};
      color: ${style.color};
      ${style.border || ''}
      transition-duration: ${motionDuration};
      transition-timing-function: ${motionEasing};
    `}
    onmouseenter={(e) => {
      if (style.hover && style.hover.includes('opacity')) {
        e.currentTarget.style.opacity = '0.9';
      } else if (style.hover && style.hover.includes('background-color')) {
        const hoverColor = style.hover.split(':')[1].trim();
        e.currentTarget.style.backgroundColor = hoverColor;
      }
    }}
    onmouseleave={(e) => {
      if (style.hover && style.hover.includes('opacity')) {
        e.currentTarget.style.opacity = '1';
      } else if (style.hover && style.hover.includes('background-color')) {
        e.currentTarget.style.backgroundColor = style.background;
      }
    }}
    onfocus={(e) => {
      e.currentTarget.style.outline = `2px solid ${style.focus}`;
      e.currentTarget.style.outlineOffset = '2px';
    }}
    onblur={(e) => {
      e.currentTarget.style.outline = '';
      e.currentTarget.style.outlineOffset = '';
    }}
    aria-label={ariaLabel}
    role="button"
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    class={`${baseClasses} ${sizeClasses[size]} ${className}`}
    style={`
      background-color: ${style.background};
      color: ${style.color};
      ${style.border || ''}
      transition-duration: ${motionDuration};
      transition-timing-function: ${motionEasing};
    `}
    onmouseenter={(e) => {
      if (!disabled && style.hover && style.hover.includes('opacity')) {
        e.currentTarget.style.opacity = '0.9';
      } else if (!disabled && style.hover && style.hover.includes('background-color')) {
        const hoverColor = style.hover.split(':')[1].trim();
        e.currentTarget.style.backgroundColor = hoverColor;
      }
    }}
    onmouseleave={(e) => {
      if (!disabled && style.hover && style.hover.includes('opacity')) {
        e.currentTarget.style.opacity = '1';
      } else if (!disabled && style.hover && style.hover.includes('background-color')) {
        e.currentTarget.style.backgroundColor = style.background;
      }
    }}
    onfocus={(e) => {
      e.currentTarget.style.outline = `2px solid ${style.focus}`;
      e.currentTarget.style.outlineOffset = '2px';
    }}
    onblur={(e) => {
      e.currentTarget.style.outline = '';
      e.currentTarget.style.outlineOffset = '';
    }}
    aria-label={ariaLabel}
  >
    <slot />
  </button>
)}
