---
/**
 * PricingTable Component
 * 
 * A theme-aware pricing table component for displaying pricing plans.
 * 
 * Architecture Decisions:
 * 1. Plans defined as TypeScript interface - type-safe, clear structure
 * 2. Popular plan highlighting uses primary token - consistent branding
 * 3. Feature lists use success token for checkmarks - semantic meaning
 * 4. CTA buttons use token-based variants - consistent with Button component
 * 5. Grid layout responsive by default - works on all screen sizes
 * 
 * This component demonstrates how to build complex UI using only tokens.
 * No hardcoded values - everything adapts to the current theme.
 */

export interface PricingPlan {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features: string[];
  cta: {
    text: string;
    href: string;
    variant?: 'primary' | 'secondary' | 'outline';
  };
  popular?: boolean;
}

export interface Props {
  plans: PricingPlan[];
  class?: string;
}

const {
  plans,
  class: className = '',
} = Astro.props;

const motionDuration = 'var(--token-motion-duration-normal)';
const motionEasing = 'var(--token-motion-easing-default)';
---

<div class={`grid md:grid-cols-3 gap-6 ${className}`}>
  {plans.map((plan) => (
    <div
      class={`relative rounded-lg border p-6 transition-all ${
        plan.popular ? 'border-2' : ''
      }`}
      style={`
        background-color: ${plan.popular ? 'var(--token-color-surface-elevated)' : 'var(--token-color-surface)'};
        border-color: ${plan.popular ? 'var(--token-color-primary)' : 'var(--token-color-border)'};
        transition-duration: ${motionDuration};
        transition-timing-function: ${motionEasing};
      `}
    >
      {plan.popular && (
        <div
          class="absolute -top-3 left-1/2 transform -translate-x-1/2 px-3 py-1 rounded-full text-xs font-semibold"
          style="background-color: var(--token-color-primary); color: var(--token-color-primary-foreground);"
        >
          Popular
        </div>
      )}
      
      <div class="text-center mb-6">
        <h3
          class="text-2xl font-bold mb-2"
          style="color: var(--token-color-text-primary);"
        >
          {plan.name}
        </h3>
        {plan.description && (
          <p
            class="text-sm mb-4"
            style="color: var(--token-color-text-muted);"
          >
            {plan.description}
          </p>
        )}
        <div class="flex items-baseline justify-center gap-1">
          <span
            class="text-4xl font-bold"
            style="color: var(--token-color-text-primary);"
          >
            {plan.price}
          </span>
          {plan.period && (
            <span
              class="text-sm"
              style="color: var(--token-color-text-muted);"
            >
              /{plan.period}
            </span>
          )}
        </div>
      </div>

      <ul class="space-y-3 mb-6">
        {plan.features.map((feature) => (
          <li class="flex items-start gap-2">
            <svg
              class="w-5 h-5 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              style="color: var(--token-color-success);"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"
              />
            </svg>
            <span style="color: var(--token-color-text-primary);">
              {feature}
            </span>
          </li>
        ))}
      </ul>

      <a
        href={plan.cta.href}
        class="block w-full text-center px-4 py-2 rounded-lg font-medium transition-all"
        {...(plan.cta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        style={`
          background-color: ${plan.cta.variant === 'outline' ? 'transparent' : plan.cta.variant === 'secondary' ? 'var(--token-color-secondary)' : 'var(--token-color-primary)'};
          color: ${plan.cta.variant === 'outline' ? 'var(--token-color-text-primary)' : plan.cta.variant === 'secondary' ? 'var(--token-color-secondary-foreground)' : 'var(--token-color-primary-foreground)'};
          ${plan.cta.variant === 'outline' ? 'border: 1px solid var(--token-color-border);' : ''}
          transition-duration: ${motionDuration};
          transition-timing-function: ${motionEasing};
        `}
        onmouseenter={(e) => {
          if (plan.cta.variant === 'outline') {
            e.currentTarget.style.backgroundColor = 'var(--token-color-hover)';
          } else {
            e.currentTarget.style.opacity = '0.9';
          }
        }}
        onmouseleave={(e) => {
          if (plan.cta.variant === 'outline') {
            e.currentTarget.style.backgroundColor = 'transparent';
          } else {
            e.currentTarget.style.opacity = '1';
          }
        }}
      >
        {plan.cta.text}
      </a>
    </div>
  ))}
</div>
