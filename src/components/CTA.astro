---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="about" class="max-w-6xl mx-auto px-4 py-20">
  <ScrollReveal client:idle scale={true}>
    <div class="rounded-2xl p-12 text-center" style="background-color: var(--token-color-primary, #000000); color: var(--token-color-primary-foreground, #ffffff);">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--token-color-primary-foreground, #ffffff);">Ready to Get Started?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto" style="color: var(--token-color-primary-foreground, #ffffff); opacity: 0.9;">
        Start building beautiful, themeable websites with a production-ready design system. Perfect for developers and agencies.
      </p>
      <a
        href="https://buy.stripe.com/8x2dR9dcZfiu4R57mX4Ja01"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg transition-opacity font-medium hover:opacity-90"
        style="background-color: var(--token-color-primary-foreground, #ffffff); color: var(--token-color-primary, #000000);"
        aria-label="Buy this template on Stripe (opens in new tab)"
      >
        <Icon name="tabler:shopping-cart" class="w-5 h-5" aria-hidden="true" />
        Buy this template
      </a>
    </div>
  </ScrollReveal>
</section>
