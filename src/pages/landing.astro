---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { Hero, Card, Button, Badge, PricingTable, Accordion } from "../components/ui/index";
import { Icon } from "astro-icon/components";
import { SITE } from "../config/site.mjs";
import splatSvg from "../assets/splat.svg";
---

<Layout
  title="Landing Page Showcase | Astro Theme Switcher"
  description="A comprehensive landing page showcasing all major components from the Astro Theme Switcher component library."
  canonicalURL={`${SITE.url}/landing`}
>
  <Header />
  <main id="main-content" role="main">
    <!-- Hero Section -->
    <section 
      class="hero-section py-12 sm:py-16 md:py-32 bg-linear-to-b from-background to-surface relative"
      style={`--splat-svg: url('${splatSvg.src}')`}
    >
      <Hero
        title="Build Amazing Websites"
        subtitle="A production-ready, token-based themeable design system that adapts to any brand. Create beautiful, accessible websites with runtime theme switching."
        primaryCta={{ text: 'View Components', href: '/components', variant: 'primary', icon: 'tabler:components' }}
        secondaryCta={{ text: 'Explore Themes', href: '/theme', variant: 'outline', icon: 'tabler:palette' }}
      />
    </section>

    <!-- Features Section -->
    <section class="py-12 sm:py-16 md:py-20" aria-labelledby="features-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <ScrollReveal client:load>
          <div class="text-center mb-12 sm:mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Features</Badge>
            <h2 id="features-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-text-primary">
              Everything You Need
            </h2>
            <p class="text-lg sm:text-xl max-w-2xl mx-auto text-text-muted px-4">
              A comprehensive component library built with semantic tokens and accessibility in mind.
            </p>
          </div>
        </ScrollReveal>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8">
          <ScrollReveal client:load delay={0.1}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div class="mb-4 flex-1 flex flex-col">
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl flex items-center justify-center mb-4 sm:mb-6 bg-primary">
                  <Icon name="tabler:palette" class="w-7 h-7 sm:w-8 sm:h-8 text-primary-foreground" aria-hidden="true" />
                </div>
                <h3 class="text-lg sm:text-xl font-semibold mb-2 text-text-primary">
                  Theme System
                </h3>
                <p class="mb-4 sm:mb-6 text-sm sm:text-base text-text-muted flex-1">
                  Runtime theme switching with semantic tokens. Switch between multiple color themes and light/dark modes instantly. Perfect for building adaptable user interfaces.
                </p>
                <Button variant="primary" size="md" href="/theme" class="text-sm sm:text-base">Learn more about themes</Button>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div class="mb-4 flex-1 flex flex-col">
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl flex items-center justify-center mb-4 sm:mb-6 bg-success">
                  <Icon name="tabler:components" class="w-7 h-7 sm:w-8 sm:h-8 text-success-foreground" aria-hidden="true" />
                </div>
                <h3 class="text-lg sm:text-xl font-semibold mb-2 text-text-primary">
                  Component Library
                </h3>
                <p class="mb-4 sm:mb-6 text-sm sm:text-base text-text-muted flex-1">
                  Production-ready components including buttons, cards, modals, toasts, tables, and more. All theme-aware and accessible.
                </p>
                <Button variant="primary" size="md" href="/components">View Components</Button>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.3}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div class="mb-4 flex-1 flex flex-col">
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl flex items-center justify-center mb-4 sm:mb-6 bg-info">
                  <Icon name="tabler:bolt" class="w-7 h-7 sm:w-8 sm:h-8 text-info-foreground" aria-hidden="true" />
                </div>
                <h3 class="text-lg sm:text-xl font-semibold mb-2 text-text-primary">
                  Fast & Accessible
                </h3>
                <p class="mb-4 sm:mb-6 text-sm sm:text-base text-text-muted flex-1">
                  Built with Astro for optimal performance. WCAG compliant with keyboard navigation, screen reader support, and proper ARIA attributes.
                </p>
                <Button variant="primary" size="md" href="/about" class="text-sm sm:text-base">Learn about accessibility</Button>
              </div>
            </Card>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-12 sm:py-16 md:py-20 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <ScrollReveal client:load>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 text-center justify-items-center">
            <div class="flex flex-col items-center">
              <div class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 text-primary">7+</div>
              <div class="text-sm sm:text-base md:text-lg text-text-muted">Color Themes</div>
            </div>
            <div class="flex flex-col items-center">
              <div class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 text-primary">15+</div>
              <div class="text-sm sm:text-base md:text-lg text-text-muted">Components</div>
            </div>
            <div class="flex flex-col items-center">
              <div class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 text-primary">100%</div>
              <div class="text-sm sm:text-base md:text-lg text-text-muted">Accessible</div>
            </div>
            <div class="flex flex-col items-center">
              <div class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 text-primary">0</div>
              <div class="text-sm sm:text-base md:text-lg text-text-muted">Hardcoded Colors</div>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-12 sm:py-16 md:py-20" aria-labelledby="testimonials-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <ScrollReveal client:load>
          <div class="text-center mb-12 sm:mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Testimonials</Badge>
            <h2 id="testimonials-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-text-primary px-4">
              Loved by Developers
            </h2>
            <p class="text-lg sm:text-xl max-w-2xl mx-auto text-text-muted px-4">
              See what developers are saying about Astro Theme Switcher.
            </p>
          </div>
        </ScrollReveal>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8">
          <ScrollReveal client:load delay={0.1}>
            <Card variant="outlined" padding="lg">
              <div class="mb-4">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full mr-3 sm:mr-4 flex items-center justify-center bg-primary text-primary-foreground text-sm sm:text-base">
                    JD
                  </div>
                  <div>
                    <div class="font-semibold text-sm sm:text-base text-text-primary">John Doe</div>
                    <div class="text-xs sm:text-sm text-text-muted">Frontend Developer</div>
                  </div>
                </div>
                <p class="text-sm sm:text-base text-text-muted">
                  "The token-based system is brilliant. I can switch themes instantly and all components adapt automatically. This is exactly what I needed for my project."
                </p>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <Card variant="outlined" padding="lg">
              <div class="mb-4">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full mr-3 sm:mr-4 flex items-center justify-center bg-success text-success-foreground text-sm sm:text-base">
                    JS
                  </div>
                  <div>
                    <div class="font-semibold text-sm sm:text-base text-text-primary">Jane Smith</div>
                    <div class="text-xs sm:text-sm text-text-muted">UI/UX Designer</div>
                  </div>
                </div>
                <p class="text-sm sm:text-base text-text-muted">
                  "The component library is comprehensive and well-designed. Every component is accessible and follows best practices. Highly recommended!"
                </p>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.3}>
            <Card variant="outlined" padding="lg">
              <div class="mb-4">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full mr-3 sm:mr-4 flex items-center justify-center bg-info text-info-foreground text-sm sm:text-base">
                    BJ
                  </div>
                  <div>
                    <div class="font-semibold text-sm sm:text-base text-text-primary">Bob Johnson</div>
                    <div class="text-xs sm:text-sm text-text-muted">Full Stack Developer</div>
                  </div>
                </div>
                <p class="text-sm sm:text-base text-text-muted">
                  "The runtime theme switching is a game-changer. No rebuilds needed, and the performance is excellent. Perfect for client projects."
                </p>
              </div>
            </Card>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="py-12 sm:py-16 md:py-20 bg-surface" aria-labelledby="pricing-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <ScrollReveal client:load>
          <div class="text-center mb-12 sm:mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Pricing</Badge>
            <h2 id="pricing-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-text-primary px-4">
              Simple, Transparent Pricing
            </h2>
            <p class="text-lg sm:text-xl max-w-2xl mx-auto text-text-muted px-4">
              Choose the plan that's right for you. All plans include full access to the component library.
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.2}>
          <PricingTable
            plans={[
              {
                name: 'Starter',
                price: '$29',
                period: 'one-time',
                description: 'Perfect for personal projects',
                features: [
                  'Full component library',
                  '7 color themes',
                  'Light/dark mode',
                  'Documentation',
                  'Email support',
                ],
                cta: { text: 'Get Started', href: '/components', variant: 'outline' },
              },
              {
                name: 'Professional',
                price: '$99',
                period: 'one-time',
                description: 'For agencies and teams',
                features: [
                  'Everything in Starter',
                  'Priority support',
                  'Commercial license',
                  'Future updates',
                  'Source code access',
                ],
                cta: { text: 'Get Started', href: '/components', variant: 'primary' },
                popular: true,
              },
              {
                name: 'Enterprise',
                price: 'Custom',
                period: '',
                description: 'For large organizations',
                features: [
                  'Everything in Professional',
                  'Dedicated support',
                  'Custom themes',
                  'Training & onboarding',
                  'SLA guarantee',
                ],
                cta: { text: 'Contact Sales', href: '/contact', variant: 'outline' },
              },
            ]}
          />
        </ScrollReveal>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 sm:py-16 md:py-20" aria-labelledby="faq-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <ScrollReveal client:load>
          <div class="text-center mb-12 sm:mb-16">
            <Badge variant="primary" size="lg" class="mb-4">FAQ</Badge>
            <h2 id="faq-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-text-primary px-4">
              Frequently Asked Questions
            </h2>
            <p class="text-lg sm:text-xl max-w-2xl mx-auto text-text-muted px-4">
              Everything you need to know about Astro Theme Switcher.
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.2}>
          <Accordion
            items={[
              {
                id: 'faq-1',
                title: 'How does the theme system work?',
                content: 'The theme system uses semantic design tokens defined as CSS custom properties. Each theme has its own token definitions for colors, typography, spacing, and more. Themes can be switched at runtime without rebuilding the site.',
              },
              {
                id: 'faq-2',
                title: 'Are the components accessible?',
                content: 'Yes! All components are built with accessibility in mind. They include proper ARIA attributes, keyboard navigation support, and follow WCAG guidelines. Screen readers are fully supported.',
              },
              {
                id: 'faq-3',
                title: 'Can I customize the themes?',
                content: 'Absolutely! Each theme is defined in TypeScript, making it easy to modify colors, fonts, spacing, and other design tokens. You can also create entirely new themes by following the same structure.',
              },
              {
                id: 'faq-4',
                title: 'Do I need to know React or Vue?',
                content: 'No! Most components are built with Astro, which means they work with zero JavaScript by default. Only interactive components like toasts and modals use React for client-side interactivity.',
              },
              {
                id: 'faq-5',
                title: 'Is this production-ready?',
                content: 'Yes! The codebase is written for commercial sale with clean architecture, comprehensive documentation, and production-quality code. It\'s ready to use in real projects.',
              },
            ]}
            allowMultiple={false}
          />
        </ScrollReveal>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 sm:py-16 md:py-20 bg-linear-to-br from-primary to-primary">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <ScrollReveal client:load>
          <Card variant="elevated" padding="lg" class="border-0">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 text-text-primary px-2">
              Ready to Get Started?
            </h2>
            <p class="text-lg sm:text-xl mb-6 sm:mb-8 max-w-2xl mx-auto text-text-muted px-2">
              Join thousands of developers building beautiful, accessible websites with Astro Theme Switcher.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
              <Button variant="primary" size="lg" href="#pricing" class="w-full sm:w-auto">
                View Pricing
              </Button>
              <Button variant="outline" size="lg" href="/components" class="w-full sm:w-auto">
                Explore Components
              </Button>
            </div>
          </Card>
        </ScrollReveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-section {
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    background-color: var(--token-color-primary, #2563eb);
    mask-image: var(--splat-svg);
    -webkit-mask-image: var(--splat-svg);
    /* Use contain to ensure the entire SVG fits without being cut off */
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center;
    -webkit-mask-position: center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    opacity: 0.1;
    transition: background-color var(--token-motion-duration-normal, 200ms) var(--token-motion-easing-default, cubic-bezier(0.4, 0, 0.2, 1));
  }

  /* Ensure Hero content is above the background */
  .hero-section > * {
    position: relative;
    z-index: 1;
  }

  /* Mobile-specific improvements */
  @media (max-width: 640px) {
    /* Prevent horizontal overflow */
    main {
      overflow-x: hidden;
    }

    /* Ensure buttons don't overflow on small screens */
    .hero-section button,
    .hero-section a[class*="Button"] {
      width: 100%;
      max-width: 100%;
    }

    /* Improve text readability on small screens */
    section {
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
  }
</style>
