---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { Hero, Card, Button, Badge, PricingTable, Accordion } from "../components/ui/index";
import { Icon } from "astro-icon/components";
import { SITE } from "../config/site.mjs";
import splatSvg from "../assets/splat.svg";
---

<Layout
  title="Landing Page Showcase | Astro Theme Switcher"
  description="A comprehensive landing page showcasing all major components from the Astro Theme Switcher component library."
  canonicalURL={`${SITE.url}/landing`}
>
  <Header />
  <main id="main-content" role="main">
    <!-- Hero Section -->
    <section 
      className="hero-section py-20 md:py-32 bg-gradient-to-b from-background to-surface relative overflow-hidden"
      style={`--splat-svg: url('${splatSvg.src}')`}
    >
      <Hero
        title="Build Amazing Websites"
        subtitle="A production-ready, token-based themeable design system that adapts to any brand. Create beautiful, accessible websites with runtime theme switching."
        primaryCta={{ text: 'Get Started', href: '#pricing', variant: 'primary' }}
        secondaryCta={{ text: 'View Components', href: '/components', variant: 'outline' }}
      />
    </section>

    <!-- Features Section -->
    <section className="py-20" aria-labelledby="features-heading">
      <div className="max-w-7xl mx-auto px-4">
        <ScrollReveal client:load>
          <div className="text-center mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Features</Badge>
            <h2 id="features-heading" className="text-4xl md:text-5xl font-bold mb-4 text-text-primary">
              Everything You Need
            </h2>
            <p className="text-xl max-w-2xl mx-auto text-text-muted">
              A comprehensive component library built with semantic tokens and accessibility in mind.
            </p>
          </div>
        </ScrollReveal>

        <div className="grid md:grid-cols-3 gap-8">
          <ScrollReveal client:load delay={0.1}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div className="mb-4 flex-1 flex flex-col">
                <div className="w-16 h-16 rounded-xl flex items-center justify-center mb-6 bg-primary">
                  <Icon name="tabler:palette" class="w-8 h-8 text-primary-foreground" aria-hidden="true" />
                </div>
                <h3 className="text-xl font-semibold mb-2 text-text-primary">
                  Theme System
                </h3>
                <p className="mb-6 text-text-muted flex-1">
                  Runtime theme switching with semantic tokens. Switch between multiple color themes and light/dark modes instantly. Perfect for building adaptable user interfaces.
                </p>
                <Button variant="outline" size="md" href="/theme">Learn more about the theme system</Button>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div className="mb-4 flex-1 flex flex-col">
                <div className="w-16 h-16 rounded-xl flex items-center justify-center mb-6 bg-success">
                  <Icon name="tabler:components" class="w-8 h-8 text-success-foreground" aria-hidden="true" />
                </div>
                <h3 className="text-xl font-semibold mb-2 text-text-primary">
                  Component Library
                </h3>
                <p className="mb-6 text-text-muted flex-1">
                  Production-ready components including buttons, cards, modals, toasts, tables, and more. All theme-aware and accessible.
                </p>
                <Button variant="outline" size="md" href="/components">View Components</Button>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.3}>
            <Card variant="elevated" padding="lg" class="h-full flex flex-col">
              <div className="mb-4 flex-1 flex flex-col">
                <div className="w-16 h-16 rounded-xl flex items-center justify-center mb-6 bg-info">
                  <Icon name="tabler:bolt" class="w-8 h-8 text-info-foreground" aria-hidden="true" />
                </div>
                <h3 className="text-xl font-semibold mb-2 text-text-primary">
                  Fast & Accessible
                </h3>
                <p className="mb-6 text-text-muted flex-1">
                  Built with Astro for optimal performance. WCAG compliant with keyboard navigation, screen reader support, and proper ARIA attributes.
                </p>
                <Button variant="outline" size="md" href="/about">Learn more about accessibility</Button>
              </div>
            </Card>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section className="py-20 bg-surface">
      <div className="max-w-7xl mx-auto px-4">
        <ScrollReveal client:load>
          <div className="grid grid-cols-1 md:grid-cols-4 gap-8 text-center justify-items-center">
            <div className="flex flex-col items-center">
              <div className="text-4xl md:text-5xl font-bold mb-2 text-primary">7+</div>
              <div className="text-lg text-text-muted">Color Themes</div>
            </div>
            <div className="flex flex-col items-center">
              <div className="text-4xl md:text-5xl font-bold mb-2 text-primary">15+</div>
              <div className="text-lg text-text-muted">Components</div>
            </div>
            <div className="flex flex-col items-center">
              <div className="text-4xl md:text-5xl font-bold mb-2 text-primary">100%</div>
              <div className="text-lg text-text-muted">Accessible</div>
            </div>
            <div className="flex flex-col items-center">
              <div className="text-4xl md:text-5xl font-bold mb-2 text-primary">0</div>
              <div className="text-lg text-text-muted">Hardcoded Colors</div>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section className="py-20" aria-labelledby="testimonials-heading">
      <div className="max-w-7xl mx-auto px-4">
        <ScrollReveal client:load>
          <div className="text-center mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Testimonials</Badge>
            <h2 id="testimonials-heading" className="text-4xl md:text-5xl font-bold mb-4 text-text-primary">
              Loved by Developers
            </h2>
            <p className="text-xl max-w-2xl mx-auto text-text-muted">
              See what developers are saying about Astro Theme Switcher.
            </p>
          </div>
        </ScrollReveal>

        <div className="grid md:grid-cols-3 gap-8">
          <ScrollReveal client:load delay={0.1}>
            <Card variant="outlined" padding="lg">
              <div className="mb-4">
                <div className="flex items-center mb-4">
                  <div className="w-12 h-12 rounded-full mr-4 flex items-center justify-center bg-primary text-primary-foreground">
                    JD
                  </div>
                  <div>
                    <div className="font-semibold text-text-primary">John Doe</div>
                    <div className="text-sm text-text-muted">Frontend Developer</div>
                  </div>
                </div>
                <p className="text-text-muted">
                  "The token-based system is brilliant. I can switch themes instantly and all components adapt automatically. This is exactly what I needed for my project."
                </p>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <Card variant="outlined" padding="lg">
              <div className="mb-4">
                <div className="flex items-center mb-4">
                  <div className="w-12 h-12 rounded-full mr-4 flex items-center justify-center bg-success text-success-foreground">
                    JS
                  </div>
                  <div>
                    <div className="font-semibold text-text-primary">Jane Smith</div>
                    <div className="text-sm text-text-muted">UI/UX Designer</div>
                  </div>
                </div>
                <p className="text-text-muted">
                  "The component library is comprehensive and well-designed. Every component is accessible and follows best practices. Highly recommended!"
                </p>
              </div>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.3}>
            <Card variant="outlined" padding="lg">
              <div className="mb-4">
                <div className="flex items-center mb-4">
                  <div className="w-12 h-12 rounded-full mr-4 flex items-center justify-center bg-info text-info-foreground">
                    BJ
                  </div>
                  <div>
                    <div className="font-semibold text-text-primary">Bob Johnson</div>
                    <div className="text-sm text-text-muted">Full Stack Developer</div>
                  </div>
                </div>
                <p className="text-text-muted">
                  "The runtime theme switching is a game-changer. No rebuilds needed, and the performance is excellent. Perfect for client projects."
                </p>
              </div>
            </Card>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" className="py-20 bg-surface" aria-labelledby="pricing-heading">
      <div className="max-w-7xl mx-auto px-4">
        <ScrollReveal client:load>
          <div className="text-center mb-16">
            <Badge variant="primary" size="lg" class="mb-4">Pricing</Badge>
            <h2 id="pricing-heading" className="text-4xl md:text-5xl font-bold mb-4 text-text-primary">
              Simple, Transparent Pricing
            </h2>
            <p className="text-xl max-w-2xl mx-auto text-text-muted">
              Choose the plan that's right for you. All plans include full access to the component library.
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.2}>
          <PricingTable
            plans={[
              {
                name: 'Starter',
                price: '$29',
                period: 'one-time',
                description: 'Perfect for personal projects',
                features: [
                  'Full component library',
                  '7 color themes',
                  'Light/dark mode',
                  'Documentation',
                  'Email support',
                ],
                cta: { text: 'Get Started', href: '#', variant: 'outline' },
              },
              {
                name: 'Professional',
                price: '$99',
                period: 'one-time',
                description: 'For agencies and teams',
                features: [
                  'Everything in Starter',
                  'Priority support',
                  'Commercial license',
                  'Future updates',
                  'Source code access',
                ],
                cta: { text: 'Get Started', href: '#', variant: 'primary' },
                popular: true,
              },
              {
                name: 'Enterprise',
                price: 'Custom',
                period: '',
                description: 'For large organizations',
                features: [
                  'Everything in Professional',
                  'Dedicated support',
                  'Custom themes',
                  'Training & onboarding',
                  'SLA guarantee',
                ],
                cta: { text: 'Contact Sales', href: '#', variant: 'outline' },
              },
            ]}
          />
        </ScrollReveal>
      </div>
    </section>

    <!-- FAQ Section -->
    <section className="py-20" aria-labelledby="faq-heading">
      <div className="max-w-4xl mx-auto px-4">
        <ScrollReveal client:load>
          <div className="text-center mb-16">
            <Badge variant="primary" size="lg" class="mb-4">FAQ</Badge>
            <h2 id="faq-heading" className="text-4xl md:text-5xl font-bold mb-4 text-text-primary">
              Frequently Asked Questions
            </h2>
            <p className="text-xl max-w-2xl mx-auto text-text-muted">
              Everything you need to know about Astro Theme Switcher.
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.2}>
          <Accordion
            items={[
              {
                id: 'faq-1',
                title: 'How does the theme system work?',
                content: 'The theme system uses semantic design tokens defined as CSS custom properties. Each theme has its own token definitions for colors, typography, spacing, and more. Themes can be switched at runtime without rebuilding the site.',
              },
              {
                id: 'faq-2',
                title: 'Are the components accessible?',
                content: 'Yes! All components are built with accessibility in mind. They include proper ARIA attributes, keyboard navigation support, and follow WCAG guidelines. Screen readers are fully supported.',
              },
              {
                id: 'faq-3',
                title: 'Can I customize the themes?',
                content: 'Absolutely! Each theme is defined in TypeScript, making it easy to modify colors, fonts, spacing, and other design tokens. You can also create entirely new themes by following the same structure.',
              },
              {
                id: 'faq-4',
                title: 'Do I need to know React or Vue?',
                content: 'No! Most components are built with Astro, which means they work with zero JavaScript by default. Only interactive components like toasts and modals use React for client-side interactivity.',
              },
              {
                id: 'faq-5',
                title: 'Is this production-ready?',
                content: 'Yes! The codebase is written for commercial sale with clean architecture, comprehensive documentation, and production-quality code. It\'s ready to use in real projects.',
              },
            ]}
            allowMultiple={false}
          />
        </ScrollReveal>
      </div>
    </section>

    <!-- CTA Section -->
    <section className="py-20 bg-gradient-to-br from-primary to-primary">
      <div className="max-w-4xl mx-auto px-4 text-center">
        <ScrollReveal client:load>
          <Card variant="elevated" padding="lg" class="border-0">
            <h2 className="text-3xl md:text-4xl font-bold mb-4 text-text-primary">
              Ready to Get Started?
            </h2>
            <p className="text-xl mb-8 max-w-2xl mx-auto text-text-muted">
              Join thousands of developers building beautiful, accessible websites with Astro Theme Switcher.
            </p>
            <div className="flex flex-col sm:flex-row gap-4 justify-center">
              <Button variant="primary" size="lg" href="#pricing">
                View Pricing
              </Button>
              <Button variant="outline" size="lg" href="/components">
                Explore Components
              </Button>
            </div>
          </Card>
        </ScrollReveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-section {
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    background-color: var(--token-color-primary, #2563eb);
    mask-image: var(--splat-svg);
    -webkit-mask-image: var(--splat-svg);
    mask-size: 62% auto;
    -webkit-mask-size: 62% auto;
    mask-position: center;
    -webkit-mask-position: center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    opacity: 0.1;
    transition: background-color var(--token-motion-duration-normal, 200ms) var(--token-motion-easing-default, cubic-bezier(0.4, 0, 0.2, 1));
  }

  /* Ensure Hero content is above the background */
  .hero-section > * {
    position: relative;
    z-index: 1;
  }
</style>
