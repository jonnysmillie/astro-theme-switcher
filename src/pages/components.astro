---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Alert from "../components/ui/Alert.astro";
import Badge from "../components/ui/Badge.astro";
import Input from "../components/ui/Input.astro";
import PricingTable from "../components/ui/PricingTable.astro";
import Modal from "../components/ui/Modal.astro";
import Accordion from "../components/ui/Accordion.astro";
import Tabs from "../components/ui/Tabs.astro";
import DataTable from "../components/ui/DataTable.astro";
import ToastContainer, { toast } from "../components/ui/ToastContainer.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Components | ${SITE.title}`}
  description="Explore the theme-aware component library: Button, Card, Alert, Badge, Input, PricingTable, and more."
  canonicalURL={`${SITE.url}/components`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--token-color-text-primary, #111827);">Component Library</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl mb-12" style="color: var(--token-color-text-muted, #374151);">
          Production-ready, theme-aware components built with semantic tokens. All components work seamlessly across all themes.
        </p>
      </ScrollReveal>

      <!-- Buttons -->
      <ScrollReveal client:load delay={0.2}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Buttons</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Variants</h3>
              <div class="flex flex-wrap gap-4">
                <Button variant="primary">Primary</Button>
                <Button variant="secondary">Secondary</Button>
                <Button variant="outline">Outline</Button>
                <Button variant="ghost">Ghost</Button>
                <Button variant="success">Success</Button>
                <Button variant="warning">Warning</Button>
                <Button variant="error">Error</Button>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Sizes</h3>
              <div class="flex flex-wrap items-center gap-4">
                <Button variant="primary" size="sm">Small</Button>
                <Button variant="primary" size="md">Medium</Button>
                <Button variant="primary" size="lg">Large</Button>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">As Links</h3>
              <div class="flex flex-wrap gap-4">
                <Button variant="primary" href="/features">Learn more about features</Button>
                <Button variant="outline" href="/about">About</Button>
              </div>
            </div>
          </div>
        </section>
      </ScrollReveal>

      <!-- Cards -->
      <ScrollReveal client:load delay={0.3}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Cards</h2>
          <div class="grid md:grid-cols-3 gap-6">
            <Card variant="default" padding="md">
              <h3 class="text-lg font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Default Card</h3>
              <p style="color: var(--token-color-text-muted, #374151);">
                A default card with subtle shadow and surface background.
              </p>
            </Card>
            <Card variant="elevated" padding="md">
              <h3 class="text-lg font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Elevated Card</h3>
              <p style="color: var(--token-color-text-muted, #374151);">
                An elevated card with stronger shadow and elevated surface.
              </p>
            </Card>
            <Card variant="outlined" padding="md">
              <h3 class="text-lg font-semibold mb-2" style="color: var(--token-color-text-primary, #111827);">Outlined Card</h3>
              <p style="color: var(--token-color-text-muted, #374151);">
                An outlined card with border and no shadow.
              </p>
            </Card>
          </div>
        </section>
      </ScrollReveal>

      <!-- Alerts -->
      <ScrollReveal client:load delay={0.4}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Alerts</h2>
          <div class="space-y-4">
            <Alert variant="success" title="Success!" dismissible>
              Your changes have been saved successfully.
            </Alert>
            <Alert variant="warning" title="Warning" dismissible>
              Please review your information before submitting.
            </Alert>
            <Alert variant="error" title="Error" dismissible>
              Something went wrong. Please try again.
            </Alert>
            <Alert variant="info" title="Information" dismissible>
              This is an informational message.
            </Alert>
          </div>
        </section>
      </ScrollReveal>

      <!-- Badges -->
      <ScrollReveal client:load delay={0.5}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Badges</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Variants</h3>
              <div class="flex flex-wrap gap-3">
                <Badge variant="default">Default</Badge>
                <Badge variant="primary">Primary</Badge>
                <Badge variant="success">Success</Badge>
                <Badge variant="warning">Warning</Badge>
                <Badge variant="error">Error</Badge>
                <Badge variant="info">Info</Badge>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Sizes</h3>
              <div class="flex flex-wrap items-center gap-3">
                <Badge variant="primary" size="sm">Small</Badge>
                <Badge variant="primary" size="md">Medium</Badge>
                <Badge variant="primary" size="lg">Large</Badge>
              </div>
            </div>
          </div>
        </section>
      </ScrollReveal>

      <!-- Inputs -->
      <ScrollReveal client:load delay={0.6}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Inputs</h2>
          <div class="max-w-md space-y-6">
            <Input
              type="text"
              label="Name"
              placeholder="Enter your name"
              required
            />
            <Input
              type="email"
              label="Email"
              placeholder="you@example.com"
              required
            />
            <Input
              type="text"
              label="Username"
              placeholder="Choose a username"
              error="This username is already taken"
            />
            <Input
              type="text"
              label="Disabled Input"
              placeholder="This is disabled"
              disabled
            />
          </div>
        </section>
      </ScrollReveal>

      <!-- Pricing Table -->
      <ScrollReveal client:load delay={0.7}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Pricing Table</h2>
          <PricingTable
            plans={[
              {
                name: 'Starter',
                price: '$9',
                period: 'month',
                description: 'Perfect for getting started',
                features: [
                  'Up to 5 projects',
                  'Basic support',
                  'Community access',
                  'Documentation',
                ],
                cta: { text: 'Get Started', href: '/signup', variant: 'outline' },
              },
              {
                name: 'Professional',
                price: '$29',
                period: 'month',
                description: 'For professionals and teams',
                features: [
                  'Unlimited projects',
                  'Priority support',
                  'Advanced features',
                  'API access',
                  'Custom integrations',
                ],
                cta: { text: 'Get Started', href: '/signup', variant: 'primary' },
                popular: true,
              },
              {
                name: 'Enterprise',
                price: '$99',
                period: 'month',
                description: 'For large organizations',
                features: [
                  'Everything in Professional',
                  'Dedicated support',
                  'Custom SLA',
                  'On-premise deployment',
                  'Training & onboarding',
                ],
                cta: { text: 'Contact Sales', href: '/contact', variant: 'outline' },
              },
            ]}
          />
        </section>
      </ScrollReveal>

      <!-- Modal -->
      <ScrollReveal client:load delay={0.8}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Modal</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Sizes</h3>
              <div class="flex flex-wrap gap-4">
                <Button variant="primary" onclick={`if (window.openModal) window.openModal('modal-sm'); else { const m = document.getElementById('modal-sm'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Open Small Modal</Button>
                <Button variant="primary" onclick={`if (window.openModal) window.openModal('modal-md'); else { const m = document.getElementById('modal-md'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Open Medium Modal</Button>
                <Button variant="primary" onclick={`if (window.openModal) window.openModal('modal-lg'); else { const m = document.getElementById('modal-lg'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Open Large Modal</Button>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Variants</h3>
              <div class="flex flex-wrap gap-4">
                <Button variant="outline" onclick={`if (window.openModal) window.openModal('modal-alert'); else { const m = document.getElementById('modal-alert'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Alert Modal</Button>
                <Button variant="outline" onclick={`if (window.openModal) window.openModal('modal-form'); else { const m = document.getElementById('modal-form'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Form Modal</Button>
              </div>
            </div>
          </div>
          
          <Modal id="modal-sm" title="Small Modal" size="sm">
            <p style="color: var(--token-color-text-primary, #111827);">
              This is a small modal dialog. Perfect for confirmations and simple messages.
            </p>
          </Modal>
          
          <Modal id="modal-md" title="Medium Modal" size="md">
            <p style="color: var(--token-color-text-primary, #111827);">
              This is a medium modal dialog. Great for forms and detailed content.
            </p>
          </Modal>
          
          <Modal id="modal-lg" title="Large Modal" size="lg">
            <p style="color: var(--token-color-text-primary, #111827);">
              This is a large modal dialog. Ideal for complex forms and rich content.
            </p>
          </Modal>
          
          <Modal id="modal-alert" title="Alert" variant="alert" size="md">
            <p style="color: var(--token-color-text-primary, #111827);">
              This is an alert modal with a red border to indicate importance.
            </p>
          </Modal>
          
          <Modal id="modal-form" title="Contact Form" variant="form" size="md">
            <div class="space-y-4">
              <Input type="text" label="Name" placeholder="Your name" />
              <Input type="email" label="Email" placeholder="your@email.com" />
              <div class="flex gap-4 pt-4">
                <Button variant="primary">Submit</Button>
                <Button variant="outline" onclick={`document.getElementById('modal-form').classList.add('hidden');`}>Cancel</Button>
              </div>
            </div>
          </Modal>
        </section>
      </ScrollReveal>

      <!-- Toast Notifications -->
      <ScrollReveal client:load delay={0.9}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Toast Notifications</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Variants</h3>
              <div class="flex flex-wrap gap-4">
                <Button variant="success" onclick={`window.toast({ message: 'Operation completed successfully!', variant: 'success' });`}>Success Toast</Button>
                <Button variant="error" onclick={`window.toast({ message: 'Something went wrong. Please try again.', variant: 'error' });`}>Error Toast</Button>
                <Button variant="warning" onclick={`window.toast({ message: 'Please review your information.', variant: 'warning' });`}>Warning Toast</Button>
                <Button variant="primary" onclick={`window.toast({ message: 'Here is some helpful information.', variant: 'info' });`}>Info Toast</Button>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">With Actions</h3>
              <Button variant="outline" onclick={`window.toast({ message: 'File uploaded successfully', variant: 'success', action: { label: 'View', onClick: () => console.log('View clicked') } });`}>Toast with Action</Button>
            </div>
          </div>
          <ToastContainer client:load />
        </section>
      </ScrollReveal>

      <script is:inline>
        // Toast queue system - works immediately, even before React loads
        (function() {
          window.__toastQueue = window.__toastQueue || [];
          
          // Create a toast function that queues toasts until ToastContainer is ready
          window.toast = function(props) {
            // If the real toast function is available, use it
            if (window.__realToast) {
              return window.__realToast(props);
            }
            
            // Otherwise, queue it
            window.__toastQueue.push(props);
            
            // Try to process the queue
            if (window.__processToastQueue) {
              window.__processToastQueue();
            }
          };
          
          // Process queued toasts when ToastContainer is ready
          window.__processToastQueue = function() {
            if (window.__realToast && window.__toastQueue.length > 0) {
              while (window.__toastQueue.length > 0) {
                var queuedToast = window.__toastQueue.shift();
                window.__realToast(queuedToast);
              }
            }
          };
        })();
      </script>

      <!-- Accordion -->
      <ScrollReveal client:load delay={1.0}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Accordion</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Single Open (Default)</h3>
              <Accordion
                items={[
                  {
                    id: 'item-1',
                    title: 'What is Astro Theme Switcher?',
                    content: 'Astro Theme Switcher is a production-ready, token-based themeable design system for Astro. It provides a comprehensive component library and runtime theme switching capabilities.',
                  },
                  {
                    id: 'item-2',
                    title: 'How do I add a new theme?',
                    content: 'To add a new theme, create a theme directory in src/themes/, define your tokens in tokens.ts, add metadata in meta.json, generate the CSS, and register it in the theme registry.',
                  },
                  {
                    id: 'item-3',
                    title: 'Are components accessible?',
                    content: 'Yes! All components are accessible by default with proper ARIA attributes, keyboard navigation, and focus management. We follow WCAG guidelines.',
                  },
                ]}
                allowMultiple={false}
              />
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Multiple Open</h3>
              <Accordion
                items={[
                  {
                    id: 'item-4',
                    title: 'Can I customize components?',
                    content: 'Absolutely! All components use semantic tokens, so they automatically adapt to your theme. You can also extend or modify components as needed.',
                  },
                  {
                    id: 'item-5',
                    title: 'Is this template production-ready?',
                    content: 'Yes! The codebase is written for commercial sale with clean architecture, comprehensive documentation, and production-quality code.',
                  },
                ]}
                allowMultiple={true}
                variant="bordered"
              />
            </div>
          </div>
        </section>
      </ScrollReveal>

      <!-- Tabs -->
      <ScrollReveal client:load delay={1.1}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Tabs</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Default Variant</h3>
              <Tabs
                items={[
                  {
                    id: 'overview',
                    label: 'Overview',
                    content: '<div class="prose"><p style="color: var(--token-color-text-primary, #111827);">This is the overview tab content. It can contain any HTML content.</p></div>',
                  },
                  {
                    id: 'features',
                    label: 'Features',
                    content: '<div class="prose"><ul style="color: var(--token-color-text-primary, #111827);"><li>Theme-aware components</li><li>Runtime theme switching</li><li>Accessible by default</li></ul></div>',
                  },
                  {
                    id: 'pricing',
                    label: 'Pricing',
                    content: '<div class="prose"><p style="color: var(--token-color-text-primary, #111827);">Pricing information goes here.</p></div>',
                  },
                ]}
                defaultTab="overview"
              />
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4" style="color: var(--token-color-text-primary, #111827);">Pills Variant</h3>
              <Tabs
                items={[
                  {
                    id: 'tab1',
                    label: 'Tab One',
                    content: '<p style="color: var(--token-color-text-primary, #111827);">Content for tab one.</p>',
                  },
                  {
                    id: 'tab2',
                    label: 'Tab Two',
                    content: '<p style="color: var(--token-color-text-primary, #111827);">Content for tab two.</p>',
                  },
                  {
                    id: 'tab3',
                    label: 'Tab Three',
                    content: '<p style="color: var(--token-color-text-primary, #111827);">Content for tab three.</p>',
                  },
                ]}
                variant="pills"
              />
            </div>
          </div>
        </section>
      </ScrollReveal>

      <!-- DataTable -->
      <ScrollReveal client:load delay={1.2}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">DataTable</h2>
          <DataTable
            data={[
              { id: 1, name: 'John Doe', email: 'john@example.com', role: 'Admin', status: 'Active' },
              { id: 2, name: 'Jane Smith', email: 'jane@example.com', role: 'User', status: 'Active' },
              { id: 3, name: 'Bob Johnson', email: 'bob@example.com', role: 'User', status: 'Inactive' },
              { id: 4, name: 'Alice Williams', email: 'alice@example.com', role: 'Editor', status: 'Active' },
              { id: 5, name: 'Charlie Brown', email: 'charlie@example.com', role: 'User', status: 'Active' },
            ]}
            columns={[
              { key: 'name', label: 'Name', sortable: true },
              { key: 'email', label: 'Email', sortable: true },
              { key: 'role', label: 'Role', sortable: true },
              { key: 'status', label: 'Status', sortable: true },
            ]}
            searchable={true}
            sortable={true}
            pagination={true}
            itemsPerPage={10}
          />
        </section>
      </ScrollReveal>

      <!-- Combined Example -->
      <ScrollReveal client:load delay={1.3}>
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6" style="color: var(--token-color-text-primary, #111827);">Combined Example</h2>
          <Card variant="elevated" padding="lg">
            <div class="flex items-center gap-3 mb-4">
              <Badge variant="success">New</Badge>
              <h3 class="text-2xl font-bold" style="color: var(--token-color-text-primary, #111827);">Feature Announcement</h3>
            </div>
            <Alert variant="info" class="mb-6">
              We've just released a new component library! Check it out below.
            </Alert>
            <div class="space-y-4 mb-6">
              <Input
                type="email"
                label="Subscribe to updates"
                placeholder="your@email.com"
              />
            </div>
            <div class="flex gap-4">
              <Button variant="primary" onclick={`window.toast({ message: 'Subscribed successfully!', variant: 'success' });`}>Subscribe</Button>
              <Button variant="outline" onclick={`if (window.openModal) window.openModal('modal-md'); else { const m = document.getElementById('modal-md'); m?.classList.remove('hidden'); m?.classList.add('flex'); }`}>Learn more about this feature</Button>
            </div>
          </Card>
        </section>
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
