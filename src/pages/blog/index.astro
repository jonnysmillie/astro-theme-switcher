---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ScrollReveal from '../../components/ScrollReveal.tsx';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE } from '../../config/site.mjs';
import { Image } from 'astro:assets';
import { getBlogImage } from '../../utils/blogImages';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
	title={`Blog | ${SITE.title}`}
	description="Read our latest blog posts about web development, Astro, and more."
	canonicalURL={`${SITE.url}/blog`}
>
	<Header />
	<main id="main-content" role="main" class="min-h-screen" style="background-color: var(--token-color-background, #ffffff);">
		<div class="max-w-7xl mx-auto px-4 py-16 md:py-24">
			<header class="text-center mb-16">
				<ScrollReveal client:load>
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4" style="color: var(--token-color-text-primary, #111827);">
						Blog
					</h1>
				</ScrollReveal>
				<ScrollReveal client:load delay={0.2}>
					<p class="text-lg md:text-xl max-w-2xl mx-auto" style="color: var(--token-color-text-muted, #6b7280);">
						Just some posts about things I've learned.
					</p>
				</ScrollReveal>
			</header>

			{blogPosts.length === 0 ? (
				<div class="text-center py-12">
					<p style="color: var(--token-color-text-muted, #6b7280);">No blog posts yet. Check back soon!</p>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{blogPosts.map((post, index) => {
						const heroImage = getBlogImage(post.data.heroImage);
						const firstTag = post.data.tags && post.data.tags.length > 0 ? post.data.tags[0] : null;
						return (
							<article class="rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden flex flex-col" style="background-color: var(--token-color-background, #ffffff);">
								<a
									href={`/blog/${post.slug}`}
									class="block group"
								>
									{heroImage && (
										<div class="w-full h-48 md:h-56 overflow-hidden rounded-t-lg">
											<Image
												src={heroImage}
												alt={post.data.title}
												transition:name={`blog-image-${post.slug}`}
												class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200 rounded-t-lg"
												style="border-radius: 0.5rem 0.5rem 0 0;"
												loading="lazy"
												widths={[400, 800, 1200]}
												sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
											/>
										</div>
									)}
									<ScrollReveal client:load delay={0.1 + index * 0.1}>
										<div class="p-6 flex flex-col flex-1">
											<div class="flex items-center gap-3 mb-3 text-sm" style="color: var(--token-color-text-muted, #6b7280);">
												<time datetime={post.data.pubDate.toISOString()}>
													{post.data.pubDate.toLocaleDateString('en-US', {
														year: 'numeric',
														month: 'short',
														day: 'numeric',
													})}
												</time>
												{firstTag && (
													<span class="px-2.5 py-1 rounded-md text-xs font-medium" style="background-color: var(--token-color-surface, #f9fafb); color: var(--token-color-text-primary, #111827);">
														{firstTag}
													</span>
												)}
											</div>
											<h2 class="text-xl md:text-2xl font-bold mb-3 transition-colors line-clamp-2" style="color: var(--token-color-text-primary, #111827);">
												{post.data.title}
											</h2>
											<p class="text-sm md:text-base flex-1 line-clamp-3" style="color: var(--token-color-text-muted, #6b7280);">
												{post.data.description}
											</p>
										</div>
									</ScrollReveal>
								</a>
							</article>
						);
					})}
				</div>
			)}
		</div>
	</main>
	<Footer />
</Layout>

<style>
	/* Critical CSS: Ensure border-radius is applied immediately to prevent FOUC */
	article a > div img,
	article a > div[data-astro-cid] img,
	article a > div > img {
		border-radius: 0.5rem 0.5rem 0 0;
	}
</style>
