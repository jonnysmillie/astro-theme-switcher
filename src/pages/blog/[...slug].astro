---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ScrollReveal from '../../components/ScrollReveal.tsx';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { SITE } from '../../config/site.mjs';
import { Image } from 'astro:assets';
import { getBlogImage } from '../../utils/blogImages';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	return blogPosts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

type Props = {
	post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
const heroImage = getBlogImage(post.data.heroImage);
// Get the image URL for ogImage meta tag
const ogImageUrl = heroImage ? new URL(heroImage.src, import.meta.env.SITE || SITE.url).href : undefined;
---

<Layout
	title={`${post.data.title} | ${SITE.title}`}
	description={post.data.description}
	canonicalURL={`${SITE.url}/blog/${post.id}`}
	ogType="article"
	ogImage={ogImageUrl}
>
	<Header />
	<main id="main-content" role="main" class="min-h-screen">
		<article class="max-w-4xl mx-auto">
			<ScrollReveal client:load>
				<div class="px-4 pt-8">
				<a
					href="/blog"
					class="inline-flex items-center gap-2 transition-colors mb-4"
					style="color: var(--token-color-text-muted, #374151);"
					onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
					onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #374151)'}
				>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="w-5 h-5"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="m12 19-7-7 7-7" />
							<path d="M19 12H5" />
						</svg>
						<span>Back to Blog</span>
					</a>
				</div>
			</ScrollReveal>
			{heroImage && (
				<div class="w-full mb-4 mt-4 px-4">
					<Image
						src={heroImage}
						alt={post.data.title}
						transition:name={`blog-image-${post.id}`}
						class="w-full h-96 md:h-[500px] object-cover rounded-lg"
						style="border-radius: 0.5rem;"
						loading="eager"
						widths={[400, 800, 1200, 1600]}
						sizes="(max-width: 768px) 100vw, 1200px"
					/>
				</div>
			)}
			<div class="px-4 pt-8 pb-16">
				<header class="mb-8">
					<ScrollReveal client:load delay={0.2}>
						<h1 class="text-4xl md:text-5xl font-bold mb-4" style="color: var(--token-color-text-primary, #111827);">
							{post.data.title}
						</h1>
					</ScrollReveal>
					<ScrollReveal client:load delay={0.3}>
						<div class="flex flex-wrap items-center gap-4 text-sm mb-6" style="color: var(--token-color-text-muted, #374151);">
							<time datetime={post.data.pubDate.toISOString()}>
								Published{' '}
								{post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
							{post.data.updatedDate && (
								<time datetime={post.data.updatedDate.toISOString()}>
									Updated{' '}
									{post.data.updatedDate.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</time>
							)}
							{post.data.author && <span>by {post.data.author}</span>}
						</div>
					</ScrollReveal>
					{post.data.tags && post.data.tags.length > 0 && (
						<ScrollReveal client:load delay={0.4}>
							<div class="flex flex-wrap gap-2 mb-6">
								{post.data.tags.map((tag) => (
								<span
									class="px-3 py-1 rounded-full text-sm"
									style="background-color: var(--token-color-surface, #f9fafb); color: var(--token-color-text-primary, #111827);"
								>
										{tag}
									</span>
								))}
							</div>
						</ScrollReveal>
					)}
				</header>

				<ScrollReveal client:load delay={0.5}>
					<div class="prose prose-lg max-w-none">
						<Content />
					</div>
				</ScrollReveal>

			<footer class="mt-12 pt-8 border-t border-gray-200">
				<a
					href="/blog"
					class="transition-colors inline-flex items-center gap-2"
					style="color: var(--token-color-text-muted, #374151);"
					onmouseenter={(e) => e.currentTarget.style.color = 'var(--token-color-text-primary, #111827)'}
					onmouseleave={(e) => e.currentTarget.style.color = 'var(--token-color-text-muted, #374151)'}
				>
					← Back to Blog
				</a>
			</footer>
		</article>
	</main>
	<Footer />
</Layout>

<style>
	/* Critical CSS: Ensure border-radius is applied immediately to prevent FOUC */
	article > div img,
	article > div[data-astro-cid] img,
	article > div > img {
		border-radius: 0.5rem;
	}
</style>
