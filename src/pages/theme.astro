---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { Card, Button, Badge } from "../components/ui/index";
import { SITE } from "../config/site.mjs";

// Code examples for the page
const tokensExample = `import type { DesignTokens } from '../types';

export const tokens: DesignTokens = {
  color: {
    primary: '#ef4444',
    primaryForeground: '#ffffff',
    secondary: '#fee2e2',
    secondaryForeground: '#7f1d1d',
    accent: '#fecaca',
    accentForeground: '#7f1d1d',
    background: '#fef2f2',
    surface: '#fee2e2',
    surfaceElevated: '#ffffff',
    text: {
      primary: '#7f1d1d',
      secondary: '#991b1b',
      muted: '#dc2626',
      inverse: '#ffffff',
    },
    border: '#fecaca',
    borderMuted: '#fee2e2',
    borderStrong: '#f87171',
    success: '#10b981',
    successForeground: '#ffffff',
    warning: '#f59e0b',
    warningForeground: '#ffffff',
    error: '#ef4444',
    errorForeground: '#ffffff',
    info: '#3b82f6',
    infoForeground: '#ffffff',
    hover: 'rgba(239, 68, 68, 0.1)',
    active: 'rgba(239, 68, 68, 0.2)',
    focus: '#ef4444',
  },
  typography: {
    fontFamily: {
      sans: 'ui-sans-serif, system-ui, ...',
      serif: 'ui-serif, Georgia, ...',
      mono: 'ui-monospace, SFMono-Regular, ...',
    },
    // ... fontSize, fontWeight, etc.
  },
  radius: {
    sm: '0.125rem',
    md: '0.375rem',
    // ... more radius values
  },
  shadow: {
    1: '0 1px 2px 0 rgb(239 68 68 / 0.1)',
    // ... more shadow values
  },
  motion: {
    duration: {
      fast: '150ms',
      normal: '200ms',
      slow: '300ms',
    },
    easing: {
      default: 'cubic-bezier(0.4, 0, 0.2, 1)',
      // ... more easing values
    },
  },
};`;

const metaExample = `{
  "id": "red",
  "name": "Red",
  "description": "Bold red color scheme",
  "version": "1.0.0",
  "premium": false,
  "tags": ["red", "bold", "energetic"]
}`;

const cssExample = `/* Red Theme - Light Mode */
[data-theme="red"][data-mode="light"] {
  --token-color-primary: #ef4444;
  --token-color-primary-foreground: #ffffff;
  --token-color-background: #fef2f2;
  --token-color-surface: #fee2e2;
  --token-color-text-primary: #7f1d1d;
  /* ... more tokens ... */
}

/* Red Theme - Dark Mode */
[data-theme="red"][data-mode="dark"] {
  --token-color-primary: #f87171;
  --token-color-primary-foreground: #ffffff;
  --token-color-background: #7f1d1d;
  --token-color-surface: #991b1b;
  --token-color-text-primary: #fee2e2;
  /* ... more tokens ... */
}`;

const registerExample = `// Import your theme
import { tokens as redTokens } from './red/tokens';
import redMeta from './red/meta.json';

// Add to themes array
export const themes: Theme[] = [
  // ... existing themes
  {
    meta: redMeta as ThemeMeta,
    tokens: redTokens,
  },
];`;

const importExample = `@import './light/theme.css';
@import './dark/theme.css';
@import './blue/theme.css';
/* ... other themes ... */
@import './red/theme.css';  ← Add your theme`;
---

<Layout
  title="How to Add a Theme | Astro Theme Switcher"
  description="Learn how to add a new theme to your Astro Theme Switcher project. Step-by-step guide with code examples."
  canonicalURL={`${SITE.url}/theme`}
>
  <Header />
  <main id="main-content" role="main">
    <!-- Hero Section -->
    <section class="py-20 bg-gradient-to-b from-background to-surface">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <ScrollReveal client:load>
          <Badge variant="primary" size="lg" class="mb-4">Documentation</Badge>
          <h1 class="text-4xl md:text-5xl font-bold mb-6 text-text-primary">
            How to Add a Theme
          </h1>
          <p class="text-xl max-w-2xl mx-auto text-text-muted">
            Learn how to create and add a new theme to your Astro Theme Switcher project. Follow these simple steps to extend the theme system.
          </p>
        </ScrollReveal>
      </div>
    </section>

    <!-- Overview Section -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-4">
        <ScrollReveal client:load>
          <Card variant="elevated" padding="lg">
            <h2 class="text-3xl font-bold mb-4 text-text-primary">Overview</h2>
            <p class="text-lg mb-6 text-text-muted">
              The theme system uses semantic design tokens defined in TypeScript. Each theme consists of three files:
            </p>
            <ul class="space-y-3 mb-6 text-text-muted">
              <li class="flex items-start">
                <span class="mr-2 text-primary">•</span>
                <span><strong class="text-text-primary">tokens.ts</strong> - Defines all design tokens (colors, typography, spacing, etc.)</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2 text-primary">•</span>
                <span><strong class="text-text-primary">meta.json</strong> - Theme metadata (name, description, version)</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2 text-primary">•</span>
                <span><strong class="text-text-primary">theme.css</strong> - Generated CSS custom properties (auto-generated from tokens)</span>
              </li>
            </ul>
            <p class="text-text-muted">
              Themes are automatically registered in the theme system and appear in the theme switcher once added.
            </p>
          </Card>
        </ScrollReveal>
      </div>
    </section>

    <!-- Step-by-Step Guide -->
    <section class="py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4">
        <ScrollReveal client:load>
          <h2 class="text-3xl font-bold mb-8 text-text-primary">Step-by-Step Guide</h2>
        </ScrollReveal>

        <!-- Step 1 -->
        <ScrollReveal client:load delay={0.1}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">1</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Create Theme Directory</h3>
                <p class="mb-4 text-text-muted">
                  Create a new directory in <code class="px-2 py-1 rounded bg-surface text-text-primary">src/themes/</code> with your theme name (e.g., <code class="px-2 py-1 rounded bg-surface text-text-primary">red</code>, <code class="px-2 py-1 rounded bg-surface text-text-primary">pink</code>).
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto"><code>src/themes/
  ├── blue/
  ├── green/
  ├── red/        ← Your new theme
  │   ├── tokens.ts
  │   ├── meta.json
  │   └── theme.css</code></pre>
                </div>
              </div>
            </div>
          </Card>
        </ScrollReveal>

        <!-- Step 2 -->
        <ScrollReveal client:load delay={0.2}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">2</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Define Design Tokens</h3>
                <p class="mb-4 text-text-muted">
                  Create <code class="px-2 py-1 rounded bg-surface text-text-primary">tokens.ts</code> with your theme's design tokens. Use semantic names (primary, surface, text.primary) rather than raw color values.
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto" set:html={`<code>${tokensExample}</code>`}></pre>
                </div>
                <p class="mt-4 text-sm text-text-muted">
                  💡 <strong>Tip:</strong> Copy an existing theme's <code class="px-1 py-0.5 rounded bg-surface text-text-primary">tokens.ts</code> file and modify the color values to match your theme.
                </p>
              </div>
            </div>
          </Card>
        </ScrollReveal>

        <!-- Step 3 -->
        <ScrollReveal client:load delay={0.3}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">3</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Add Theme Metadata</h3>
                <p class="mb-4 text-text-muted">
                  Create <code class="px-2 py-1 rounded bg-surface text-text-primary">meta.json</code> with your theme's information.
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto" set:html={`<code>${metaExample}</code>`}></pre>
                </div>
              </div>
            </div>
          </Card>
        </ScrollReveal>

        <!-- Step 4 -->
        <ScrollReveal client:load delay={0.4}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">4</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Create Theme CSS</h3>
                <p class="mb-4 text-text-muted">
                  Create <code class="px-2 py-1 rounded bg-surface text-text-primary">theme.css</code> with CSS custom properties for both light and dark modes. Copy from an existing theme and update the values.
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto" set:html={`<code>${cssExample}</code>`}></pre>
                </div>
                <p class="mt-4 text-sm text-text-muted">
                  💡 <strong>Tip:</strong> Copy <code class="px-1 py-0.5 rounded bg-surface text-text-primary">theme.css</code> from an existing theme (e.g., <code class="px-1 py-0.5 rounded bg-surface text-text-primary">blue/theme.css</code>) and replace all color values with your theme's colors.
                </p>
              </div>
            </div>
          </Card>
        </ScrollReveal>

        <!-- Step 5 -->
        <ScrollReveal client:load delay={0.5}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">5</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Register the Theme</h3>
                <p class="mb-4 text-text-muted">
                  Add your theme to the theme registry in <code class="px-2 py-1 rounded bg-surface text-text-primary">src/themes/index.ts</code>.
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto" set:html={`<code>${registerExample}</code>`}></pre>
                </div>
              </div>
            </div>
          </Card>
        </ScrollReveal>

        <!-- Step 6 -->
        <ScrollReveal client:load delay={0.6}>
          <Card variant="outlined" padding="lg" class="mb-8">
            <div class="flex items-start mb-4">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold mr-4 flex-shrink-0">6</div>
              <div class="flex-1">
                <h3 class="text-2xl font-semibold mb-3 text-text-primary">Import Theme CSS</h3>
                <p class="mb-4 text-text-muted">
                  Add your theme's CSS import to <code class="px-2 py-1 rounded bg-surface text-text-primary">src/themes/themes.css</code>.
                </p>
                <div class="bg-surface rounded-lg p-4 border border-border">
                  <pre class="text-sm text-text-primary overflow-x-auto" set:html={`<code>${importExample}</code>`}></pre>
                </div>
              </div>
            </div>
          </Card>
        </ScrollReveal>
      </div>
    </section>

    <!-- Best Practices -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-4">
        <ScrollReveal client:load>
          <h2 class="text-3xl font-bold mb-8 text-text-primary">Best Practices</h2>
        </ScrollReveal>

        <div class="grid md:grid-cols-2 gap-6">
          <ScrollReveal client:load delay={0.1}>
            <Card variant="elevated" padding="lg">
              <h3 class="text-xl font-semibold mb-3 text-text-primary">Use Semantic Tokens</h3>
              <p class="text-text-muted">
                Always use semantic token names (primary, surface, text.primary) rather than raw color values. This ensures your theme works with all components automatically.
              </p>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <Card variant="elevated" padding="lg">
              <h3 class="text-xl font-semibold mb-3 text-text-primary">Ensure Contrast</h3>
              <p class="text-text-muted">
                Make sure text colors have sufficient contrast against their backgrounds. Use WCAG AA standards (4.5:1 for normal text, 3:1 for large text).
              </p>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.3}>
            <Card variant="elevated" padding="lg">
              <h3 class="text-xl font-semibold mb-3 text-text-primary">Test Both Modes</h3>
              <p class="text-text-muted">
                Each color theme should have distinct light and dark mode variants. Test both modes to ensure readability and visual appeal.
              </p>
            </Card>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.4}>
            <Card variant="elevated" padding="lg">
              <h3 class="text-xl font-semibold mb-3 text-text-primary">Follow Naming Conventions</h3>
              <p class="text-text-muted">
                Use lowercase, kebab-case for theme IDs (e.g., "red", "dark-blue"). Keep names descriptive and consistent with existing themes.
              </p>
            </Card>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <ScrollReveal client:load>
          <h2 class="text-3xl font-bold mb-4 text-text-primary">Ready to Create Your Theme?</h2>
          <p class="text-xl mb-8 text-text-muted">
            Start by copying an existing theme and customizing it to match your brand.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button variant="primary" size="lg" href="/components">
              View Components
            </Button>
            <Button variant="outline" size="lg" href="/">
              Back to Home
            </Button>
          </div>
        </ScrollReveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
